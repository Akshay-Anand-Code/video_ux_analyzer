e product demo video.\n        </p>\n      </div>\n\n      {!videoUrl ? (\n        <div\n          onDrop={handleDrop}\n          onDragOver={(e) => {\n            e.preventDefault();\n            setIsDragging(true);\n          }}\n          onDragLeave={() => setIsDragging(false)}\n          onClick={() => inputRef.current?.click()}\n          className={`\n            border-2 border-dashed rounded-3xl p-16 text-center cursor-pointer transition-all duration-200 shadow-sm\n            ${\n              isDragging\n                ? \"border-primary bg-primary/5\"\n                : \"border-border hover:border-primary/50 bg-card\"\n            }\n          `}\n        >\n          <div className=\"flex flex-col items-center gap-4\">\n            <div className=\"w-14 h-14 rounded-2xl bg-violet-100 flex items-center justify-center\">\n              <Video className=\"w-7 h-7 text-violet-600\" />\n            </div>\n            <div>\n              <p className=\"text-sm font-medium text-foreground\">\n                Drop your product demo video here\n              </p>\n              <p className=\"text-xs text-muted-foreground mt-1\">\n                MP4, MOV, WebM · 1–5 minutes recommended\n              </p>\n            </div>\n            <span className=\"text-xs text-muted-foreground border border-border bg-muted/50 rounded-lg px-3 py-1\">\n              or click to browse\n            </span>\n          </div>\n          <input\n            ref={inputRef}\n            type=\"file\"\n            accept=\"video/*\"\n            onChange={handleChange}\n            className=\"hidden\"\n          />\n        </div>\n      ) : (\n        <div className=\"rounded-3xl overflow-hidden bg-card border border-border shadow-sm\">\n          <video ref={videoRef} src={videoUrl} controls className=\"w-full aspect-video\" />\n        </div>\n      )}\n\n      {videoUrl && (\n        <div className=\"flex gap-3\">\n          <Button\n            onClick={onAnalyze}\n            disabled={isAnalyzing}\n            size=\"lg\"\n            className=\"flex-1 h-11 rounded-xl shadow-sm shadow-primary/20\"\n          >\n            {isAnalyzing ? (\n              <>\n                <Loader2 className=\"w-4 h-4 animate-spin\" />\n                Analyzing...\n              </>\n            ) : (\n              \"Analyze UX\"\n            )}\n          </Button>\n          {!isAnalyzing && (\n            <Button\n              onClick={onReset}\n              variant=\"outline\"\n              size=\"lg\"\n              className=\"h-11 rounded-xl\"\n            >\n              Change\n            </Button>\n          )}\n        </div>\n      )}\n    </div>\n  );\n}\n","structuredPatch":[{"oldStart":1,"oldLines":6,"newStart":1,"newLines":8,"lines":[" \"use client\";"," "," import { useCallback, useRef, useState } from \"react\";","+import { Video, Loader2 } from \"lucide-react\";","+import { Button } from \"@/components/ui/button\";"," "," interface Props {","   onFileSelect: (file: File) => void;"]},{"oldStart":42,"oldLines":9,"newStart":44,"newLines":12,"lines":[" ","   return (","     <div className=\"space-y-4\">","-      <h2 className=\"text-xs font-semibold text-slate-500 uppercase tracking-widest\">","-        Video Input","-      </h2>","+      <div>","+        <h2 className=\"text-2xl font-bold text-foreground\">Video Input</h2>","+        <p className=\"text-sm text-muted-foreground mt-1\">","+          Upload a 1–5 minute product demo video.","+        </p>","+      </div>"," ","       {!videoUrl ? (","         <div"]},{"oldStart":56,"oldLines":39,"newStart":61,"newLines":27,"lines":["           onDragLeave={() => setIsDragging(false)}","           onClick={() => inputRef.current?.click()}","           className={`","-            border-2 border-dashed rounded-2xl p-16 text-center cursor-pointer transition-all duration-200","+            border-2 border-dashed rounded-3xl p-16 text-center cursor-pointer transition-all dura