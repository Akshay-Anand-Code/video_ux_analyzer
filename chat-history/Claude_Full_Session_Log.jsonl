est\">\n        Video Input\n      </h2>\n\n      {!videoUrl ? (\n        <div\n          onDrop={handleDrop}\n          onDragOver={(e) => {\n            e.preventDefault();\n            setIsDragging(true);\n          }}\n          onDragLeave={() => setIsDragging(false)}\n          onClick={() => inputRef.current?.click()}\n          className={`\n            border-2 border-dashed rounded-2xl p-16 text-center cursor-pointer transition-all duration-200\n            ${\n              isDragging\n                ? \"border-violet-500 bg-violet-500/10\"\n                : \"border-slate-700 hover:border-slate-500 bg-slate-900/50\"\n            }\n          `}\n        >\n          <div className=\"flex flex-col items-center gap-4\">\n            <div className=\"w-14 h-14 rounded-2xl bg-slate-800 flex items-center justify-center\">\n              <svg\n                className=\"w-7 h-7 text-slate-400\"\n                fill=\"none\"\n                viewBox=\"0 0 24 24\"\n                stroke=\"currentColor\"\n              >\n                <path\n                  strokeLinecap=\"round\"\n                  strokeLinejoin=\"round\"\n                  strokeWidth={1.5}\n                  d=\"M15 10l4.553-2.069A1 1 0 0121 8.87v6.26a1 1 0 01-1.447.894L15 14M3 8a2 2 0 012-2h8a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V8z\"\n                />\n              </svg>\n            </div>\n            <div>\n              <p className=\"text-sm font-medium text-slate-300\">\n                Drop your product demo video here\n              </p>\n              <p className=\"text-xs text-slate-500 mt-1\">\n                MP4, MOV, WebM · 1–5 minutes recommended\n              </p>\n            </div>\n            <span className=\"text-xs text-slate-600 border border-slate-700 rounded-lg px-3 py-1\">\n              or click to browse\n            </span>\n          </div>\n          <input\n            ref={inputRef}\n            type=\"file\"\n            accept=\"video/*\"\n            onChange={handleChange}\n            className=\"hidden\"\n          />\n        </div>\n      ) : (\n        <div className=\"rounded-2xl overflow-hidden bg-slate-900 border border-slate-800\">\n          <video ref={videoRef} src={videoUrl} controls className=\"w-full aspect-video\" />\n        </div>\n      )}\n\n      {videoUrl && (\n        <div className=\"flex gap-3\">\n          <button\n            onClick={onAnalyze}\n            disabled={isAnalyzing}\n            className={`\n              flex-1 py-3 px-6 rounded-xl font-medium text-sm transition-all duration-200\n              ${\n                isAnalyzing\n                  ? \"bg-slate-800 text-slate-500 cursor-not-allowed\"\n                  : \"bg-violet-600 hover:bg-violet-500 text-white shadow-lg shadow-violet-900/30\"\n              }\n            `}\n          >\n            {isAnalyzing ? (\n              <span className=\"flex items-center justify-center gap-2\">\n                <svg\n                  className=\"animate-spin w-4 h-4\"\n                  fill=\"none\"\n                  viewBox=\"0 0 24 24\"\n                >\n                  <circle\n                    className=\"opacity-25\"\n                    cx=\"12\"\n                    cy=\"12\"\n                    r=\"10\"\n                    stroke=\"currentColor\"\n                    strokeWidth=\"4\"\n                  />\n                  <path\n                    className=\"opacity-75\"\n                    fill=\"currentColor\"\n                    d=\"M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z\"\n                  />\n                </svg>\n                Analyzing...\n              </span>\n            ) : (\n              \"Analyze UX\"\n            )}\n          </button>\n          {!isAnalyzing && (\n            <button\n              onClick={onReset}\n              className=\"px-4 py-3 rounded-xl text-sm text-slate-400 hover:text-slate-200 border border-slate-700 hover:border-slate-600 transition-all\"\n            >\n              Change\n            </button>\n          )}\n        </div>\n      )}\n    </div>\n  );\n}\n","userModified":false},"sourceToolAssistantUUID":"8e58e6c2-c5d1-4b70-af87-2dfef7e07713","userType":"external","entrypoint":"claude-vscode","cwd":"/home/akshay/projects/video_ux_analyzer","sessionId":"43aa6f4e-238a-49ff-bcee-676bf9b5ead2","version":"2.1.118","gitBranch":"HEAD"}
