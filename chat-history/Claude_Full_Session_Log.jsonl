oice: {\n62\t    label: \"Stylistic Choice\",\n63\t    dot: \"bg-sky-500\",\n64\t    badge: \"bg-sky-500/15 text-sky-400 border border-sky-500/25\",\n65\t  },\n66\t  needs_investigation: {\n67\t    label: \"Needs Investigation\",\n68\t    dot: \"bg-amber-500\",\n69\t    badge: \"bg-amber-500/15 text-amber-400 border border-amber-500/25\",\n70\t  },\n71\t};\n72\t\n73\tconst SEVERITY_CONFIG = {\n74\t  critical: { label: \"Critical\", cls: \"bg-red-600/20 text-red-400 border border-red-600/30\" },\n75\t  major: { label: \"Major\", cls: \"bg-orange-600/20 text-orange-400 border border-orange-600/30\" },\n76\t  minor: { label: \"Minor\", cls: \"bg-yellow-600/20 text-yellow-400 border border-yellow-600/30\" },\n77\t};\n78\t\n79\tconst CATEGORY_LABELS: Record<string, string> = {\n80\t  navigation: \"Navigation\",\n81\t  ui_element: \"UI Element\",\n82\t  user_flow: \"User Flow\",\n83\t  accessibility: \"Accessibility\",\n84\t  interaction_delay: \"Interaction Delay\",\n85\t  unclear_messaging: \"Unclear Messaging\",\n86\t};\n87\t\n88\tfunction IssueCard({ issue }: { issue: ValidatedIssue }) {\n89\t  const verdict = VERDICT_CONFIG[issue.verdict];\n90\t  const severity = SEVERITY_CONFIG[issue.severity];\n91\t\n92\t  return (\n93\t    <div className=\"bg-slate-900 border border-slate-800 rounded-xl p-4 space-y-3\">\n94\t      <div className=\"flex items-start justify-between gap-3\">\n95\t        <div className=\"flex flex-wrap gap-2\">\n96\t          <span className=\"text-xs px-2 py-0.5 rounded-md bg-slate-800 text-slate-400 border border-slate-700\">\n97\t            {CATEGORY_LABELS[issue.category] ?? issue.category}\n98\t          </span>\n99\t          <span className={`text-xs px-2 py-0.5 rounded-md font-medium ${severity.cls}`}>\n100\t            {severity.label}\n101\t          </span>\n102\t        </div>\n103\t        <span className={`shrink-0 text-xs px-2.5 py-1 rounded-full font-medium flex items-center gap-1.5 ${verdict.badge}`}>\n104\t          <span className={`w-1.5 h-1.5 rounded-full ${verdict.dot}`} />\n105\t          {verdict.label}\n106\t        </span>\n107\t      </div>\n108\t\n109\t      <p className=\"text-sm text-slate-200 leading-relaxed\">{issue.description}</p>\n110\t\n111\t      <div className=\"space-y-1.5\">\n112\t        {issue.timestamp && (\n113\t          <p className=\"text-xs text-slate-500 flex items-center gap-1.5\">\n114\t            <svg className=\"w-3 h-3\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n115\t              <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={2} d=\"M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z\" />\n116\t            </svg>\n117\t            {issue.timestamp}\n118\t          </p>\n119\t        )}\n120\t        <p className=\"text-xs text-slate-500 italic leading-relaxed\">\n121\t          <span className=\"text-slate-600 not-italic\">Critic: </span>\n122\t          {issue.criticReasoning}\n123\t        </p>\n124\t      </div>\n125\t    </div>\n126\t  );\n127\t}\n128\t\n129\tfunction sortIssues(issues: ValidatedIssue[]): ValidatedIssue[] {\n130\t  const severityOrder = { critical: 0, major: 1, minor: 2 };\n131\t  const verdictOrder = { genuine_bug: 0, needs_investigation: 1, stylistic_choice: 2 };\n132\t  return [...issues].sort(\n133\t    (a, b) =>\n134\t      severityOrder[a.severity] - severityOrder[b.severity] ||\n135\t      verdictOrder[a.verdict] - verdictOrder[b.verdict]\n136\t  );\n137\t}\n138\t\n139\texport default function AnalysisResults({ stage, message, data, researcherCount }: Props) {\n140\t  const isActive = stage !== \"idle\" && stage !== \"complete\" && stage !== \"error\";\n141\t\n142\t  if (stage === \"idle\") {\n143\t    return (\n144\t      <div className=\"h-full flex flex-col items-center justify-center py-24 text-center gap-4\">\n145\t        <div className=\"w-16 h-16 rounded-2xl bg-slate-900 border border-slate-800 flex items-center justify-center\">\n146\t          <svg className=\"w-8 h-8 text-slate-600\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n147\t            <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={1.5}\n148\t              d=\"M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2\"\n149\t            />\n150\t          </svg>\n151\t        </div>\n152\t        <div>\n153\t          <p className=\"text-sm font-medium text-slate-400\">No analysis yet</p>\n154\t          <p className=\"text-xs text-slate-600 mt-1\">Upload a video and click Analyze UX</p>\n155\t        </div>\n156\t      </div>\n157\t    );\n158\t  }\n159\t\n160\t  if (stage === \"error\") {\n161\t    return (\n162\t      <div className=\"bg-red-900/20 border border-red-800/50 rounded-2xl p-6 space-y-2\">\n163\t        <p className=\"text-sm font-semibold text-red-400\">Analysis failed</p>\n164\t        <p className=\"text-xs text-red-400/70\">{message}</p>\n165\t      </div>\n166\t    );\n167\t  }\n168\t\n169\t  return (\n170\t    <div className=\"space-y-6\">\n171\t      <h2 className=\"text-xs font-semibold text-slate-500 uppercase tracking-widest\">\n172\t        Analysis Results\n173\t      </h2>\n174\t\n175\t      {/* Progress stepper */}\n176\t      {isActive && (\n177\t        <div className=\"bg-slate-900 border border-slate-800 rounded-2xl p-5 space-y-4\">\n178\t          <div className=\"space-y-3\">\n179\t            {STEPS.map((step) => {\n180\t              const status = getStepStatus(step, stage);\n181\t              return (\n182\t                <div key={step.key} className=\"flex items-center gap-3\">\n183\t                  <div className={`w-5 h-5 rounded-full flex items-center justify-center shrink-0 transition-all\n184\t                    ${status === \"done\" ? \"bg-violet-600\" : status === \"active\" ? \"bg-violet-600/30 ring-2 ring-violet-500\" : \"bg-slate-800\"}\n185\t                  `}>\n186\t                    {status === \"done\" ? (\n187\t                      <svg className=\"w-3 h-3 text-white\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n188\t                        <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={2.5} d=\"M5 13l4 4L19 7\" />\n189\t                      </svg>\n190\t                    ) : status === \"active\" ? (\n191\t                      <div className=\"w-2 h-2 rounded-full bg-violet-400 animate-pulse\" />\n192\t                    ) : (\n193\t                      <div className=\"w-2 h-2 rounded-full bg-slate-600\" />\n194\t                    )}\n195\t                  </div>\n196\t                  <span className={`text-sm transition-colors\n197\t                    ${status === \"active\" ? \"text-slate-200 font-medium\" : status === \"done\" ? \"text-slate-400\" : \"text-slate-600\"}\n198\t                  `}>\n199\t                    {step.label}\n200\t                    {status === \"active\" && step.key === \"critic\" && researcherCount > 0 && (\n201\t                      <span className=\"text-slate-500 font-normal\"> · reviewing {researcherCount} findings</span>\n202\t                    )}\n203\t                  </span>\n204\t                </div>\n205\t              );\n206\t            })}\n207\t          </div>\n208\t          <p className=\"text-xs text-slate-500 pt-1 border-t border-slate-800\">{message}</p>\n209\t        </div>\n210\t      )}\n211\t\n212\t      {/* Results */}\n213\t      {stage === \"complete\" && data && (\n214\t        <div className=\"space-y-5\">\n215\t          {/* Stats */}\n216\t          <div className=\"grid grid-cols-3 gap-3\">\n217\t            {[\n218\t              { label: \"Total Issues\", value: data.validatedIssues.length, color: \"text-slate-200\" },\n219\t              {\n220\t                label: \"Genuine Bugs\",\n221\t                value: data.validatedIssues.filter((i) => i.verdict === \"genuine_bug\").length,\n222\t                color: \"text-red-400\",\n223\t              },\n224\t              {\n225\t                label: \"Stylistic\",\n226\t                value: data.validatedIssues.filter((i) => i.verdict === \"stylistic_choice\").length,\n227\t                color: \"text-sky-400\",\n228\t              },\n229\t            ].map((stat) => (\n230\t              <div key={stat.label} className=\"bg-slate-900 border border-slate-800 rounded-xl p-3 text-center\">\n231\t                <p className={`text-2xl font-bold ${stat.color}`}>{stat.value}</p>\n232\t                <p className=\"text-xs text-slate-500 mt-0.5\">{stat.label}</p>\n233\t              </div>\n234\t            ))}\n235\t          </div>\n236\t\n237\t          {/* Overall assessment */}\n238\t          <div className=\"bg-violet-900/20 border border-violet-800/40 rounded-xl p-4\">\n239\t            <p className=\"text-xs font-semibold text-violet-400 mb-2 uppercase tracking-wider\">Overall Assessment</p>\n240\t            <p className=\"text-sm text-slate-300 leading-relaxed\">{data.overallAssessment}</p>\n241\t          </div>\n242\t\n243\t          {/* Issue cards */}\n244\t          <div className=\"space-y-3\">\n245\t            {sortIssues(data.validatedIssues).map((issue) => (\n246\t              <IssueCard key={issue.id} issue={issue} />\n247\t            ))}\n248\t          </div>\n249\t        </div>\n250\t      )}\n251\t    </div>\n252\t  );\n253\t}\n254\t"}]},"uuid":"0a28ed26-1a9c-466d-a8d7-4bdb3451a286","timestamp":"2026-04-24T12:09:38.047Z","toolUseResult":{"type":"text","file":{"filePath":"/home/akshay/projects/video_ux_analyzer/src/components/AnalysisResults.tsx","content":"\"use client\";\n\nimport type { AnalysisResult, AnalysisStage, ValidatedIssue } from \"@/types/analysis\";\n\ninterface Props {\n  stage: AnalysisStage;\n  message: string;\n  data: AnalysisResult | null;\n  researcherCount: number;\n}\n\nconst STEPS = [\n  {\n    key: \"upload\",\n    label: \"Upload & Process\",\n    activeStages: [\"uploading\", \"processing\"] as AnalysisStage[],\n  },\n  {\n    key: \"research\",\n    label: \"UX Research\",\n    activeStages: [\"researching\"] as AnalysisStage[],\n  },\n  {\n    key: \"critic\",\n    label: \"Critic Review\",\n    activeStages: [\"critiquing\"] as AnalysisStage[],\n  },\n];\n\nconst STAGE_ORDER: AnalysisStage[] = [\n  \"idle\",\n  \"uploading\",\n  \"processing\",\n  \"researching\",\n  \"critiquing\",\n  \"complete\",\n];\n\nfunction getStepStatus(\n  step: (typeof STEPS)[0],\n  currentStage: AnalysisStage\n): \"pending\" | \"active\" | \"done\" {\n  const currentIndex = STAGE_ORDER.indexOf(currentStage);\n  const stepFirstIndex = Math.min(\n    ...step.activeStages.map((s) => STAGE_ORDER.indexOf(s))\n  );\n  const stepLastIndex = Math.max(\n    ...step.activeStages.map((s) => STAGE_ORDER.indexOf(s))\n  );\n  if (currentIndex > stepLastIndex) return \"done\";\n  if (currentIndex >= stepFirstIndex) return \"active\";\n  return \"pending\";\n}\n\nconst VERDICT_CONFIG = {\n  genuine_bug: {\n    label: \"Genuine Bug\",\n    dot: \"bg-red-500\",\n    badge: \"bg-red-500/15 text-red-400 border border-red-500/25\",\n  },\n  stylistic_choice: {\n    label: \"Stylistic Choice\",\n    dot: \"bg-sky-500\",\n    badge: \"bg-sky-500/15 text-sky-400 border border-sky-500/25\",\n  },\n  needs_investigation: {\n    label: \"Needs Investigation\",\n    dot: \"bg-amber-500\",\n    badge: \"bg-amber-500/15 text-amber-400 border border-amber-500/25\",\n  },\n};\n\nconst SEVERITY_CONFIG = {\n  critical: { label: \"Critical\", cls: \"bg-red-600/20 text-red-400 border border-red-600/30\" },\n  major: { label: \"Major\", cls: \"bg-orange-600/20 text-orange-400 border border-orange-600/30\" },\n  minor: { label: \"Minor\", cls: \"bg-yellow-600/20 text-yellow-400 border border-yellow-600/30\" },\n};\n\nconst CATEGORY_LABELS: Record<string, string> = {\n  navigation: \"Navigation\",\n  ui_element: \"UI Element\",\n  user_flow: \"User Flow\",\n  accessibility: \"Accessibility\",\n  interaction_delay: \"Interaction Delay\",\n  unclear_messaging: \"Unclear Messaging\",\n};\n\nfunction IssueCard({ issue }: { issue: ValidatedIssue }) {\n  const verdict = VERDICT_CONFIG[issue.verdict];\n  const severity = SEVERITY_CONFIG[issue.severity];\n\n  return (\n    <div className=\"bg-slate-900 border border-slate-800 rounded-xl p-4 space-y-3\">\n      <div className=\"flex items-start justify-between gap-3\">\n        <div className=\"flex flex-wrap gap-2\">\n          <span className=\"text-xs px-2 py-0.5 rounded-md bg-slate-800 text-slate-400 border border-slate-700\">\n            {CATEGORY_LABELS[issue.category] ?? issue.category}\n          </span>\n          <span className={`text-xs px-2 py-0.5 rounded-md font-medium ${severity.cls}`}>\n            {severity.label}\n          </span>\n        </div>\n        <span className={`shrink-0 text-xs px-2.5 py-1 rounded-full font-medium flex items-center gap-1.5 ${verdict.badge}`}>\n          <span className={`w-1.5 h-1.5 rounded-full ${verdict.dot}`} />\n          {verdict.label}\n        </span>\n      </div>\n\n      <p className=\"text-sm text-slate-200 leading-relaxed\">{issue.description}</p>\n\n      <div className=\"space-y-1.5\">\n        {issue.timestamp && (\n          <p className=\"text-xs text-slate-500 flex items-center gap-1.5\">\n            <svg className=\"w-3 h-3\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n              <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={2} d=\"M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z\" />\n            </svg>\n            {issue.timestamp}\n          </p>\n        )}\n        <p className=\"text-xs text-slate-500 italic leading-relaxed\">\n          <span className=\"text-slate-600 not-italic\">Critic: </span>\n          {issue.criticReasoning}\n        </p>\n      </div>\n    </div>\n  );\n}\n\nfunction sortIssues(issues: ValidatedIssue[]): ValidatedIssue[] {\n  const severityOrder = { critical: 0, major: 1, minor: 2 };\n  const verdictOrder = { genuine_bug: 0, needs_investigation: 1, stylistic_choice: 2 };\n  return [...issues].sort(\n    (a, b) =>\n      severityOrder[a.severity] - severityOrder[b.severity] ||\n      verdictOrder[a.verdict] - verdictOrder[b.verdict]\n  );\n}\n\nexport default function AnalysisResults({ stage, message, data, researcherCount }: Props) {\n  const isActive = stage !== \"idle\" && stage !== \"complete\" && stage !== \"error\";\n\n  if (stage === \"idle\") {\n    return (\n      <div className=\"h-full flex flex-col items-center justify-center py-24 text-center gap-4\">\n        <div className=\"w-16 h-16 rounded-2xl bg-slate-900 border border-slate-800 flex items-center justify-center\">\n          <svg className=\"w-8 h-8 text-slate-600\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n            <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={1.5}\n              d=\"M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2\"\n            />\n          </svg>\n        </div>\n        <div>\n          <p className=\"text-sm font-medium text-slate-400\">No analysis yet</p>\n          <p className=\"text-xs text-slate-600 mt-1\">Upload a video and click Analyze UX</p>\n        </div>\n      </div>\n    );\n  }\n\n  if (stage === \"error\") {\n    return (\n      <div className=\"bg-red-900/20 border border-red-800/50 rounded-2xl p-6 space-y-2\">\n        <p className=\"text-sm font-semibold text-red-400\">Analysis failed</p>\n        <p className=\"text-xs text-red-400/70\">{message}</p>\n      </div>\n    );\n  }\n\n  return (\n    <div className=\"space-y-6\">\n      <h2 className=\"text-xs font-semibold text-slate-500 uppercase tracking-widest\">\n        Analysis Results\n      </h2>\n\n      {/* Progress stepper */}\n      {isActive && (\n        <div className=\"bg-slate-900 border border-slate-800 rounded-2xl p-5 space-y-4\">\n          <div className=\"space-y-3\">\n            {STEPS.map((step) => {\n              const status = getStepStatus(step, stage);\n              return (\n                <div key={step.key} className=\"flex items-center gap-3\">\n                  <div className={`w-5 h-5 rounded-full flex items-center justify-center shrink-0 transition-all\n                    ${status === \"done\" ? \"bg-violet-600\" : status === \"active\" ? \"bg-violet-600/30 ring-2 ring-violet-500\" : \"bg-slate-800\"}\n                  `}>\n                    {status === \"done\" ? (\n                      <svg className=\"w-3 h-3 text-white\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n                        <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={2.5} d=\"M5 13l4 4L19 7\" />\n                      </svg>\n                    ) : status === \"active\" ? (\n                      <div className=\"w-2 h-2 rounded-full bg-violet-400 animate-pulse\" />\n                    ) : (\n                      <div className=\"w-2 h-2 rounded-full bg-slate-600\" />\n                    )}\n                  </div>\n                  <span className={`text-sm transition-colors\n                    ${status === \"active\" ? \"text-slate-200 font-medium\" : status === \"done\" ? \"text-slate-400\" : \"text-slate-600\"}\n                  `}>\n                    {step.label}\n                    {status === \"active\" && step.key === \"critic\" && researcherCount > 0 && (\n                      <span className=\"text-slate-500 font-normal\"> · reviewing {researcherCount} findings</span>\n                    )}\n                  </span>\n                </div>\n              );\n            })}\n          </div>\n          <p className=\"text-xs text-slate-500 pt-1 border-t border-slate-800\">{message}</p>\n        </div>\n      )}\n\n      {/* Results */}\n      {stage === \"complete\" && data && (\n        <div className=\"space-y-5\">\n          {/* Stats */}\n          <div className=\"grid grid-cols-3 gap-3\">\n            {[\n              { label: \"Total Issues\", value: data.validatedIssues.length, color: \"text-slate-200\" },\n              {\n                label: \"Genuine Bugs\",\n                value: data.validatedIssues.filter((i) => i.verdict === \"genuine_bug\").length,\n                color: \"text-red-400\",\n              },\n              {\n                label: \"Stylistic\",\n                value: data.validatedIssues.filter((i) => i.verdict === \"stylistic_choice\").length,\n                color: \"text-sky-400\",\n              },\n            ].map((stat) => (\n              <div key={stat.label} className=\"bg-slate-900 border border-slate-800 rounded-xl p-3 text-center\">\n                <p className={`text-2xl font-bold ${stat.color}`}>{stat.value}</p>\n                <p className=\"text-xs text-slate-500 mt-0.5\">{stat.label}</p>\n              </div>\n            ))}\n          </div>\n\n          {/* Overall assessment */}\n          <div className=\"bg-violet-900/20 border border-violet-800/40 rounded-xl p-4\">\n            <p className=\"text-xs font-semibold text-violet-400 mb-2 uppercase tracking-wider\">Overall Assessment</p>\n            <p className=\"text-sm text-slate-300 leading-relaxed\">{data.overallAssessment}</p>\n          </div>\n\n          {/* Issue cards */}\n          <div className=\"space-y-3\">\n            {sortIssues(data.validatedIssues).map((issue) => (\n              <IssueCard key={issue.id} issue={issue} />\n            ))}\n          </div>\n        </div>\n      )}\n    </div>\n  );\n}\n","numLines":254,"startLine":1,"totalLines":254}},"sourceToolAssistantUUID":"55beffd3-9484-45ab-84ae-f5ff954e9934","userType":"external","entrypoint":"claude-vscode","cwd":"/home/akshay/projects/video_ux_analyzer","sessionId":"43aa6f4e-238a-49ff-bcee-676bf9b5ead2","version":"2.1.118","gitBranch":"HEAD"}
