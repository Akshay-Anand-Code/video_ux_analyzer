{"parentUuid":"b36de4fa-788d-43d8-b635-c8056212f2bd","isSidechain":false,"message":{"model":"claude-opus-4-7","id":"msg_016SLTzJ7wyoC5gnyZAthY47","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01JTc7m8tfacRiBQ7UJWReS6","name":"Write","input":{"file_path":"/home/akshay/projects/video_ux_analyzer/src/components/JiraTicketModal.tsx","content":"\"use client\";\n\nimport { useMemo, useState } from \"react\";\nimport {\n  ChevronDown,\n  Clock,\n  ExternalLink,\n  Film,\n  Paperclip,\n  Play,\n  Plus,\n  Scissors,\n} from \"lucide-react\";\nimport type { ValidatedIssue } from \"@/types/analysis\";\nimport {\n  Dialog,\n  DialogContent,\n  DialogDescription,\n  DialogTitle,\n} from \"@/components/ui/dialog\";\nimport { Tabs, TabsContent, TabsList, TabsTrigger } from \"@/components/ui/tabs\";\nimport { Button } from \"@/components/ui/button\";\n\ntype IssueType = \"Bug\" | \"Task\" | \"Spike\" | \"Story\";\ntype Priority = \"Highest\" | \"High\" | \"Medium\" | \"Low\" | \"Lowest\";\n\ninterface Props {\n  issue: ValidatedIssue | null;\n  onClose: () => void;\n}\n\nconst JIRA_BASE_URL =\n  process.env.NEXT_PUBLIC_JIRA_BASE_URL || \"https://your-company.atlassian.net\";\nconst JIRA_PROJECT_ID = process.env.NEXT_PUBLIC_JIRA_PROJECT_ID || \"10000\";\n\nconst PRIORITY_CONFIG: Record<\n  Priority,\n  { wrap: string; icon: string; iconColor: string }\n> = {\n  Highest: {\n    wrap: \"bg-red-500/15 text-red-300 border-red-500/40\",\n    icon: \"⇈\",\n    iconColor: \"text-red-400\",\n  },\n  High: {\n    wrap: \"bg-orange-500/15 text-orange-300 border-orange-500/40\",\n    icon: \"↑\",\n    iconColor: \"text-orange-400\",\n  },\n  Medium: {\n    wrap: \"bg-yellow-500/15 text-yellow-300 border-yellow-500/40\",\n    icon: \"=\",\n    iconColor: \"text-yellow-400\",\n  },\n  Low: {\n    wrap: \"bg-sky-500/15 text-sky-300 border-sky-500/40\",\n    icon: \"↓\",\n    iconColor: \"text-sky-400\",\n  },\n  Lowest: {\n    wrap: \"bg-slate-500/15 text-slate-300 border-slate-500/40\",\n    icon: \"⇊\",\n    iconColor: \"text-slate-400\",\n  },\n};\n\nconst ISSUE_TYPE_CONFIG: Record<IssueType, { bg: string; icon: string }> = {\n  Bug: { bg: \"bg-red-500\", icon: \"●\" },\n  Task: { bg: \"bg-blue-500\", icon: \"✓\" },\n  Spike: { bg: \"bg-purple-500\", icon: \"◆\" },\n  Story: { bg: \"bg-green-500\", icon: \"▲\" },\n};\n\nconst CATEGORY_COLORS: Record<string, string> = {\n  navigation: \"bg-purple-500/15 text-purple-300 border-purple-500/30\",\n  ui_element: \"bg-blue-500/15 text-blue-300 border-blue-500/30\",\n  user_flow: \"bg-emerald-500/15 text-emerald-300 border-emerald-500/30\",\n  accessibility: \"bg-pink-500/15 text-pink-300 border-pink-500/30\",\n  interaction_delay: \"bg-orange-500/15 text-orange-300 border-orange-500/30\",\n  unclear_messaging: \"bg-teal-500/15 text-teal-300 border-teal-500/30\",\n};\n\nfunction labelColor(label: string): string {\n  return (\n    CATEGORY_COLORS[label] ??\n    \"bg-slate-700/40 text-slate-300 border-slate-600/50\"\n  );\n}\n\nfunction verdictToIssueType(verdict: ValidatedIssue[\"verdict\"]): IssueType {\n  if (verdict === \"genuine_bug\") return \"Bug\";\n  if (verdict === \"stylistic_choice\") return \"Task\";\n  return \"Spike\";\n}\n\nfunction severityToPriority(severity: ValidatedIssue[\"severity\"]): Priority {\n  if (severity === \"critical\") return \"Highest\";\n  if (severity === \"major\") return \"High\";\n  return \"Medium\";\n}\n\nfunction defaultSummary(description: string): string {\n  const first = description.split(/(?<=[.!?])\\s/)[0]?.trim() ?? description;\n  if (first.length <= 80) return first;\n  return first.slice(0, 79).trimEnd() + \"…\";\n}\n\nfunction buildDescription(issue: ValidatedIssue): string {\n  const lines: string[] = [];\n  lines.push(\"h2. Observed issue\");\n  lines.push(issue.description);\n  lines.push(\"\");\n  lines.push(\"h2. Category\");\n  lines.push(issue.category.replace(/_/g, \" \"));\n  lines.push(\"\");\n  lines.push(\"h2. AI Critic Verdict\");\n  lines.push(\n    `*${issue.verdict.replace(/_/g, \" \")}* — ${issue.criticReasoning}`\n  );\n  if (issue.timestamp) {\n    lines.push(\"\");\n    lines.push(\"h2. Reproduce at\");\n    lines.push(issue.timestamp);\n  }\n  lines.push(\"\");\n  lines.push(\"----\");\n  lines.push(\"_Generated by Video UX Analyzer_\");\n  return lines.join(\"\\n\");\n}\n\nfunction parseTimestamp(ts: string): number {\n  const parts = ts.split(\":\").map(Number);\n  if (parts.length === 3)\n    return (parts[0] ?? 0) * 3600 + (parts[1] ?? 0) * 60 + (parts[2] ?? 0);\n  if (parts.length === 2) return (parts[0] ?? 0) * 60 + (parts[1] ?? 0);\n  return parseFloat(ts) || 0;\n}\n\nfunction formatTimestamp(seconds: number): string {\n  const total = Math.max(0, Math.floor(seconds));\n  const h = Math.floor(total / 3600);\n  const m = Math.floor((total % 3600) / 60);\n  const s = total % 60;\n  if (h > 0)\n    return `${h}:${String(m).padStart(2, \"0\")}:${String(s).padStart(2, \"0\")}`;\n  return `${m}:${String(s).padStart(2, \"0\")}`;\n}\n\nfunction JiraIcon() {\n  return (\n    <svg viewBox=\"0 0 32 32\" className=\"w-8 h-8 shrink-0\">\n      <defs>\n        <linearGradient id=\"jiraGrad1\" x1=\"0%\" y1=\"0%\" x2=\"100%\" y2=\"100%\">\n          <stop offset=\"0%\" stopColor=\"#2684FF\" />\n          <stop offset=\"100%\" stopColor=\"#0052CC\" />\n        </linearGradient>\n        <linearGradient id=\"jiraGrad2\" x1=\"100%\" y1=\"0%\" x2=\"0%\" y2=\"100%\">\n          <stop offset=\"0%\" stopColor=\"#2684FF\" />\n          <stop offset=\"100%\" stopColor=\"#0052CC\" />\n        </linearGradient>\n      </defs>\n      <path\n        d=\"M16 3 L28 15 L16 27 L13 24 L22 15 L13 6 Z\"\n        fill=\"url(#jiraGrad1)\"\n      />\n      <path\n        d=\"M13 6 L22 15 L13 24 L4 15 Z\"\n        fill=\"url(#jiraGrad2)\"\n        opacity=\"0.9\"\n      />\n    </svg>\n  );\n}\n\nfunction SnippetMock({\n  anchorSeconds,\n  anchorLabel,\n}: {\n  anchorSeconds: number;\n  anchorLabel: string;\n}) {\n  const defaultStart = Math.max(0, anchorSeconds - 3);\n  const defaultEnd = anchorSeconds + 3;\n  const [start, setStart] = useState(formatTimestamp(defaultStart));\n  const [end, setEnd] = useState(formatTimestamp(defaultEnd));\n\n  const duration = Math.max(\n    0,\n    parseTimestamp(end) - parseTimestamp(start)\n  );\n\n  return (\n    <div className=\"space-y-4\">\n      <div className=\"rounded-xl border border-dashed border-border bg-muted/20 p-5 space-y-4\">\n        <div className=\"flex items-start gap-3\">\n          <div className=\"w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center shrink-0\">\n            <Film className=\"w-5 h-5 text-primary\" />\n          </div>\n          <div className=\"flex-1 min-w-0\">\n            <p className=\"text-sm font-medium text-foreground\">\n              Video snippet\n            </p>\n            <p className=\"text-xs text-muted-foreground mt-0.5\">\n              Clip a segment around{\" \"}\n              <span className=\"text-primary font-medium\">{anchorLabel}</span>{\" \"}\n              to give reviewers context.\n            </p>\n          </div>\n          <span className=\"text-[10px] px-1.5 py-0.5 rounded bg-muted text-muted-foreground border border-border shrink-0\">\n            MOCK\n          </span>\n        </div>\n\n        {/* Timeline bar */}\n        <div className=\"relative h-2 rounded-full bg-muted overflow-hidden\">\n          <div\n            className=\"absolute inset-y-0 bg-primary/50\"\n            style={{ left: \"25%\", right: \"25%\" }}\n          />\n          <div\n            className=\"absolute top-1/2 w-3 h-3 rounded-full bg-primary border-2 border-card -translate-y-1/2\"\n            style={{ left: \"calc(25% - 6px)\" }}\n          />\n          <div\n            className=\"absolute top-1/2 w-3 h-3 rounded-full bg-primary border-2 border-card -translate-y-1/2\"\n            style={{ right: \"calc(25% - 6px)\" }}\n          />\n        </div>\n\n        <div className=\"grid grid-cols-3 gap-3\">\n          <div>\n            <label className=\"block text-[10px] font-semibold text-muted-foreground mb-1 uppercase tracking-wider\">\n              Start\n            </label>\n            <input\n              type=\"text\"\n              value={start}\n              onChange={(e) => setStart(e.target.value)}\n              className=\"w-full px-2 py-1.5 bg-background border border-border rounded-md text-xs text-foreground font-mono focus:border-primary focus:outline-none\"\n            />\n          </div>\n          <div>\n            <label className=\"block text-[10px] font-semibold text-muted-foreground mb-1 uppercase tracking-wider\">\n              End\n            </label>\n            <input\n              type=\"text\"\n              value={end}\n              onChange={(e) => setEnd(e.target.value)}\n              className=\"w-full px-2 py-1.5 bg-background border border-border rounded-md text-xs text-foreground font-mono focus:border-primary focus:outline-none\"\n            />\n          </div>\n          <div>\n            <label className=\"block text-[10px] font-semibold text-muted-foreground mb-1 uppercase tracking-wider\">\n              Duration\n            </label>\n            <div className=\"w-full px-2 py-1.5 bg-muted/40 border border-border rounded-md text-xs text-muted-foreground font-mono flex items-center gap-1\">\n              <Clock className=\"w-3 h-3\" />\n              {duration}s\n            </div>\n          </div>\n        </div>\n\n        <div className=\"flex items-center gap-2 pt-1\">\n          <Button\n            size=\"sm\"\n            variant=\"outline\"\n            disabled\n            title=\"Coming soon\"\n            className=\"gap-1.5\"\n          >\n            <Play className=\"w-3.5 h-3.5\" />\n            Preview\n          </Button>\n          <Button\n            size=\"sm\"\n            variant=\"secondary\"\n            disabled\n            title=\"Coming soon\"\n            className=\"gap-1.5\"\n          >\n            <Scissors className=\"w-3.5 h-3.5\" />\n            Clip &amp; Attach\n          </Button>\n          <span className=\"text-[10px] text-muted-foreground ml-auto\">\n            Attachment upload coming soon\n          </span>\n        </div>\n      </div>\n\n      <button\n        disabled\n        className=\"w-full flex items-center justify-center gap-2 py-3 rounded-xl border border-dashed border-border text-xs text-muted-foreground hover:border-primary/50 transition-colors disabled:opacity-60 disabled:cursor-not-allowed\"\n      >\n        <Plus className=\"w-3.5 h-3.5\" />\n        Add another snippet\n      </button>\n\n      <div className=\"flex items-center gap-2 text-[11px] text-muted-foreground\">\n        <Paperclip className=\"w-3 h-3\" />\n        <span>0 attachments · No files will be uploaded yet</span>\n      </div>\n    </div>\n  );\n}\n\nexport default function JiraTicketModal({ issue, onClose }: Props) {\n  const open = issue !== null;\n\n  // Keep last non-null issue so the modal doesn't flash empty while closing.\n  const [cached, setCached] = useState<ValidatedIssue | null>(issue);\n  if (issue && issue !== cached) setCached(issue);\n  const current = issue ?? cached;\n\n  const [summary, setSummary] = useState(\"\");\n  const [issueType, setIssueType] = useState<IssueType>(\"Bug\");\n  const [priority, setPriority] = useState<Priority>(\"Medium\");\n  const [labels, setLabels] = useState<string[]>([]);\n  const [description, setDescription] = useState(\"\");\n  const [newLabel, setNewLabel] = useState(\"\");\n\n  // Reset form state each time a new issue opens the modal.\n  useMemo(() => {\n    if (!issue) return;\n    setSummary(defaultSummary(issue.description));\n    setIssueType(verdictToIssueType(issue.verdict));\n    setPriority(severityToPriority(issue.severity));\n    setLabels([issue.category]);\n    setDescription(buildDescription(issue));\n    setNewLabel(\"\");\n  }, [issue]);\n\n  const handleAddLabel = () => {\n    const trimmed = newLabel.trim().toLowerCase().replace(/\\s+/g, \"_\");\n    if (trimmed && !labels.includes(trimmed)) {\n      setLabels([...labels, trimmed]);\n    }\n    setNewLabel(\"\");\n  };\n\n  const handleRemoveLabel = (label: string) => {\n    setLabels(labels.filter((l) => l !== label));\n  };\n\n  const handleSubmit = () => {\n    const url = new URL(\n      `${JIRA_BASE_URL}/secure/CreateIssueDetails!init.jspa`\n    );\n    url.searchParams.set(\"pid\", JIRA_PROJECT_ID);\n    url.searchParams.set(\"issuetype\", issueType);\n    url.searchParams.set(\"summary\", summary);\n    url.searchParams.set(\"description\", description);\n    url.searchParams.set(\"priority\", priority);\n    if (labels.length) url.searchParams.set(\"labels\", labels.join(\",\"));\n    window.open(url.toString(), \"_blank\", \"noopener,noreferrer\");\n    onClose();\n  };\n\n  const pCfg = PRIORITY_CONFIG[priority];\n  const tCfg = ISSUE_TYPE_CONFIG[issueType];\n\n  const anchorSeconds = current?.timestamp\n    ? parseTimestamp(current.timestamp)\n    : 0;\n  const anchorLabel = current?.timestamp ?? \"0:00\";\n\n  return (\n    <Dialog open={open} onOpenChange={(o) => !o && onClose()}>\n      <DialogContent\n        showCloseButton={false}\n        className=\"p-0 gap-0\"\n      >\n        {/* Header with Jira breadcrumb */}\n        <div className=\"flex items-center gap-3 px-6 py-4 border-b border-border bg-card/60\">\n          <JiraIcon />\n          <div className=\"flex-1 min-w-0\">\n            <div className=\"flex items-center gap-1.5 text-xs text-muted-foreground\">\n              <span className=\"text-[#4c9aff] font-medium\">UX Project</span>\n              <span className=\"text-muted-foreground/60\">/</span>\n              <span>Analysis</span>\n            </div>\n            <DialogTitle className=\"text-sm mt-0.5\">Create Issue</DialogTitle>\n            <DialogDescription className=\"sr-only\">\n              Review and edit the Jira ticket details before creation.\n            </DialogDescription>\n          </div>\n        </div>\n\n        <div className=\"flex-1 overflow-y-auto px-6 py-5\">\n          <Tabs defaultValue=\"details\" className=\"w-full\">\n            <TabsList>\n              <TabsTrigger value=\"details\">Details</TabsTrigger>\n              <TabsTrigger value=\"attachments\" className=\"gap-1.5\">\n                <Paperclip className=\"w-3 h-3\" />\n                Attachments\n              </TabsTrigger>\n            </TabsList>\n\n            <TabsContent value=\"details\" className=\"space-y-5\">\n              {/* Summary */}\n              <div>\n                <label className=\"block text-xs font-semibold text-muted-foreground mb-1.5\">\n                  Summary <span className=\"text-red-400\">*</span>\n                </label>\n                <input\n                  type=\"text\"\n                  value={summary}\n                  onChange={(e) => setSummary(e.target.value)}\n                  className=\"w-full px-3 py-2 bg-background border border-border rounded-lg text-sm text-foreground focus:border-primary focus:ring-1 focus:ring-primary focus:outline-none transition-colors\"\n                />\n              </div>\n\n              {/* Type & Priority row */}\n              <div className=\"grid grid-cols-2 gap-4\">\n                <div>\n                  <label className=\"block text-xs font-semibold text-muted-foreground mb-1.5\">\n                    Issue Type\n                  </label>\n                  <div className=\"flex items-center gap-2 px-3 py-2 bg-background border border-border rounded-lg focus-within:border-primary transition-colors\">\n                    <span\n                      className={`w-5 h-5 rounded flex items-center justify-center text-[10px] text-white ${tCfg.bg}`}\n                    >\n                      {tCfg.icon}\n                    </span>\n                    <select\n                      value={issueType}\n                      onChange={(e) =>\n                        setIssueType(e.target.value as IssueType)\n                      }\n                      className=\"flex-1 bg-transparent text-sm text-foreground focus:outline-none appearance-none cursor-pointer\"\n                    >\n                      <option value=\"Bug\" className=\"bg-card\">Bug</option>\n                      <option value=\"Task\" className=\"bg-card\">Task</option>\n                      <option value=\"Spike\" className=\"bg-card\">Spike</option>\n                      <option value=\"Story\" className=\"bg-card\">Story</option>\n                    </select>\n                    <ChevronDown className=\"w-4 h-4 text-muted-foreground\" />\n                  </div>\n                </div>\n                <div>\n                  <label className=\"block text-xs font-semibold text-muted-foreground mb-1.5\">\n                    Priority\n                  </label>\n                  <div\n                    className={`flex items-center gap-2 px-3 py-2 border rounded-lg transition-colors ${pCfg.wrap}`}\n                  >\n                    <span\n                      className={`font-bold text-base leading-none ${pCfg.iconColor}`}\n                    >\n                      {pCfg.icon}\n                    </span>\n                    <select\n                      value={priority}\n                      onChange={(e) => setPriority(e.target.value as Priority)}\n                      className=\"flex-1 bg-transparent text-sm focus:outline-none appearance-none cursor-pointer font-medium\"\n                    >\n                      <option value=\"Highest\" className=\"bg-card text-foreground\">Highest</option>\n                      <option value=\"High\" className=\"bg-card text-foreground\">High</option>\n                      <option value=\"Medium\" className=\"bg-card text-foreground\">Medium</option>\n                      <option value=\"Low\" className=\"bg-card text-foreground\">Low</option>\n                      <option value=\"Lowest\" className=\"bg-card text-foreground\">Lowest</option>\n                    </select>\n                    <ChevronDown className={`w-4 h-4 ${pCfg.iconColor}`} />\n                  </div>\n                </div>\n              </div>\n\n              {/* Labels */}\n              <div>\n                <label className=\"block text-xs font-semibold text-muted-foreground mb-1.5\">\n                  Labels\n                </label>\n                <div className=\"flex flex-wrap items-center gap-2 px-3 py-2 bg-background border border-border rounded-lg min-h-[2.5rem] focus-within:border-primary transition-colors\">\n                  {labels.map((l) => (\n                    <span\n                      key={l}\n                      className={`inline-flex items-center gap-1.5 px-2 py-0.5 rounded-md text-xs font-medium border ${labelColor(l)}`}\n                    >\n                      {l.replace(/_/g, \" \")}\n                      <button\n                        type=\"button\"\n                        onClick={() => handleRemoveLabel(l)}\n                        className=\"hover:text-white leading-none\"\n                        aria-label={`Remove ${l}`}\n                      >\n                        ×\n                      </button>\n                    </span>\n                  ))}\n                  <input\n                    type=\"text\"\n                    value={newLabel}\n                    onChange={(e) => setNewLabel(e.target.value)}\n                    onKeyDown={(e) => {\n                      if (e.key === \"Enter\") {\n                        e.preventDefault();\n                        handleAddLabel();\n                      } else if (\n                        e.key === \"Backspace\" &&\n                        !newLabel &&\n                        labels.length\n                      ) {\n                        handleRemoveLabel(labels[labels.length - 1]);\n                      }\n                    }}\n                    onBlur={handleAddLabel}\n                    placeholder={labels.length ? \"\" : \"Add label...\"}\n                    className=\"flex-1 min-w-[80px] bg-transparent text-xs text-foreground focus:outline-none\"\n                  />\n                </div>\n              </div>\n\n              {/* Description */}\n              <div>\n                <label className=\"block text-xs font-semibold text-muted-foreground mb-1.5\">\n                  Description\n                </label>\n                <textarea\n                  value={description}\n                  onChange={(e) => setDescription(e.target.value)}\n                  rows={9}\n                  className=\"w-full px-3 py-2 bg-background border border-border rounded-lg text-xs text-foreground font-mono leading-relaxed focus:border-primary focus:ring-1 focus:ring-primary focus:outline-none resize-y\"\n                />\n              </div>\n\n              {/* Reporter / Assignee */}\n              <div className=\"grid grid-cols-2 gap-4\">\n                <div>\n                  <label className=\"block text-xs font-semibold text-muted-foreground mb-1.5\">\n                    Reporter\n                  </label>\n                  <div className=\"flex items-center gap-2 px-3 py-2 bg-background border border-border rounded-lg\">\n                    <div className=\"w-6 h-6 rounded-full bg-gradient-to-br from-violet-500 to-violet-700 flex items-center justify-center text-xs font-bold text-white\">\n                      U\n                    </div>\n                    <span className=\"text-sm text-foreground\">\n                      UX Analyzer Bot\n                    </span>\n                  </div>\n                </div>\n                <div>\n                  <label className=\"block text-xs font-semibold text-muted-foreground mb-1.5\">\n                    Assignee\n                  </label>\n                  <div className=\"flex items-center gap-2 px-3 py-2 bg-background border border-border rounded-lg\">\n                    <div className=\"w-6 h-6 rounded-full bg-muted border border-dashed border-muted-foreground/50 flex items-center justify-center text-xs text-muted-foreground\">\n                      ?\n                    </div>\n                    <span className=\"text-sm text-muted-foreground\">\n                      Unassigned\n                    </span>\n                  </div>\n                </div>\n              </div>\n            </TabsContent>\n\n            <TabsContent value=\"attachments\">\n              <SnippetMock\n                anchorSeconds={anchorSeconds}\n                anchorLabel={anchorLabel}\n              />\n            </TabsContent>\n          </Tabs>\n        </div>\n\n        {/* Footer */}\n        <div className=\"px-6 py-4 border-t border-border bg-card/60 flex items-center justify-between gap-3\">\n          <p className=\"text-xs text-muted-foreground hidden sm:flex items-center gap-1.5\">\n            <ExternalLink className=\"w-3 h-3\" />\n            Opens Jira in a new tab with fields pre-filled\n          </p>\n          <div className=\"flex gap-2 ml-auto\">\n            <Button variant=\"ghost\" onClick={onClose}>\n              Cancel\n            </Button>\n            <Button onClick={handleSubmit} disabled={!summary.trim()}>\n              Create Issue\n            </Button>\n          </div>\n        </div>\n      </DialogContent>\n    </Dialog>\n  );\n}\n"},"caller":{"type":"direct"}}],"stop_reason":"tool_use","stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":399,"cache_read_input_tokens":189528,"output_tokens":8576,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":399,"ephemeral_5m_input_tokens":0},"inference_geo":"","ite