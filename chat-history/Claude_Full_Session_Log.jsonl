se)}\n          onClick={() => inputRef.current?.click()}\n          className={`\n            border-2 border-dashed rounded-3xl p-16 text-center cursor-pointer transition-all duration-200 shadow-sm\n            ${\n              isDragging\n                ? \"border-primary bg-primary/5\"\n                : \"border-border hover:border-primary/50 bg-card\"\n            }\n          `}\n        >\n          <div className=\"flex flex-col items-center gap-4\">\n            <div className=\"w-14 h-14 rounded-2xl bg-violet-100 flex items-center justify-center\">\n              <Video className=\"w-7 h-7 text-violet-600\" />\n            </div>\n            <div>\n              <p className=\"text-sm font-medium text-foreground\">\n                Drop your product demo video here\n              </p>\n              <p className=\"text-xs text-muted-foreground mt-1\">\n                MP4, MOV, WebM · 1–5 minutes recommended\n              </p>\n            </div>\n            <span className=\"text-xs text-muted-foreground border border-border bg-muted/50 rounded-lg px-3 py-1\">\n              or click to browse\n            </span>\n          </div>\n          <input\n            ref={inputRef}\n            type=\"file\"\n            accept=\"video/*\"\n            onChange={handleChange}\n            className=\"hidden\"\n          />\n        </div>\n      ) : (\n        <div className=\"rounded-3xl overflow-hidden bg-card border border-border shadow-sm\">\n          <video ref={videoRef} src={videoUrl} controls className=\"w-full aspect-video\" />\n        </div>\n      )}\n\n      {videoUrl && (\n        <div className=\"flex gap-3\">\n          <Button\n            onClick={onAnalyze}\n            disabled={isAnalyzing}\n            size=\"lg\"\n            className=\"flex-1 h-11 rounded-xl shadow-sm shadow-primary/20\"\n          >\n            {isAnalyzing ? (\n              <>\n                <Loader2 className=\"w-4 h-4 animate-spin\" />\n                Analyzing...\n              </>\n            ) : (\n              \"Analyze UX\"\n            )}\n          </Button>\n          {!isAnalyzing && (\n            <Button\n              onClick={onReset}\n              variant=\"outline\"\n              size=\"lg\"\n              className=\"h-11 rounded-xl\"\n            >\n              Change\n            </Button>\n          )}\n        </div>\n      )}\n    </div>\n  );\n}\n"},"caller":{"type":"direct"}}],"stop_reason":"tool_use","stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":2211,"cache_read_input_tokens":227297,"output_tokens":1565,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":2211,"ephemeral_5m_input_tokens":0},"inference_geo":"","iterations":[{"input_tokens":1,"output_tokens":1565,"cache_read_input_tokens":227297,"cache_creation_input_tokens":2211,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":2211},"type":"message"}],"speed":"standard"}},"requestId":"req_011CaP8MHD3knYjoZd9dPNgs","type":"assistant","uuid":"8e58e6c2-c5d1-4b70-af87-2dfef7e07713","timestamp":"2026-04-24T19:12:50.857Z","userType":"external","entrypoint":"claude-vscode","cwd":"/home/akshay/projects/video_ux_analyzer","sessionId":"43aa6f4e-238a-49ff-bcee-676bf9b5ead2","version":"2.1.118","gitBranch":"HEAD"}
