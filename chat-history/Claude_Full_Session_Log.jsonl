             {step.label}\n                    {status === \"active\" &&\n                      step.key === \"validate\" &&\n                      progress.total > 0 && (\n                        <span className=\"text-slate-500 font-normal\">\n                          {\" \"}\n                          · {progress.validated}/{progress.total}\n                        </span>\n                      )}\n                  </span>\n                </div>\n              );\n            })}\n          </div>\n          <p className=\"text-xs text-slate-500 pt-1 border-t border-slate-800\">\n            {message}\n          </p>\n        </div>\n      )}\n\n      {(stage === \"complete\" || showFindings) && (\n        <div className=\"space-y-5\">\n          <div className=\"grid grid-cols-3 gap-3\">\n            {[\n              {\n                label: \"Total Issues\",\n                value: researcherFindings.length,\n                color: \"text-slate-200\",\n              },\n              {\n                label: \"Genuine Bugs\",\n                value: genuineBugs,\n                color: \"text-red-400\",\n              },\n              {\n                label: \"Stylistic\",\n                value: stylistic,\n                color: \"text-sky-400\",\n              },\n            ].map((stat) => (\n              <div\n                key={stat.label}\n                className=\"bg-slate-900 border border-slate-800 rounded-xl p-3 text-center\"\n              >\n                <p className={`text-2xl font-bold ${stat.color}`}>{stat.value}</p>\n                <p className=\"text-xs text-slate-500 mt-0.5\">{stat.label}</p>\n              </div>\n            ))}\n          </div>\n\n          {overallAssessment && (\n            <div className=\"bg-violet-900/20 border border-violet-800/40 rounded-xl p-4 animate-in fade-in duration-500\">\n              <p className=\"text-xs font-semibold text-violet-400 mb-2 uppercase tracking-wider\">\n               