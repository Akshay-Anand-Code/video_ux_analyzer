Record<IssueType, { bg: string; icon: string }> = {\n  Bug: { bg: \"bg-red-500\", icon: \"●\" },\n  Task: { bg: \"bg-blue-500\", icon: \"✓\" },\n  Spike: { bg: \"bg-purple-500\", icon: \"◆\" },\n  Story: { bg: \"bg-green-500\", icon: \"▲\" },\n};\n\nconst CATEGORY_COLORS: Record<string, string> = {\n  navigation: \"bg-purple-500/15 text-purple-300 border-purple-500/30\",\n  ui_element: \"bg-blue-500/15 text-blue-300 border-blue-500/30\",\n  user_flow: \"bg-emerald-500/15 text-emerald-300 border-emerald-500/30\",\n  accessibility: \"bg-pink-500/15 text-pink-300 border-pink-500/30\",\n  interaction_delay: \"bg-orange-500/15 text-orange-300 border-orange-500/30\",\n  unclear_messaging: \"bg-teal-500/15 text-teal-300 border-teal-500/30\",\n};\n\nfunction labelColor(label: string): string {\n  return (\n    CATEGORY_COLORS[label] ??\n    \"bg-slate-700/40 text-slate-300 border-slate-600/50\"\n  );\n}\n\nfunction verdictToIssueType(verdict: ValidatedIssue[\"verdict\"]): IssueType {\n  if (verdict === \"genuine_bug\") return \"Bug\";\n  if (verdict === \"stylistic_choice\") return \"Task\";\n  return \"Spike\";\n}\n\nfunction severityToPriority(severity: ValidatedIssue[\"severity\"]): Priority {\n  if (severity === \"critical\") return \"Highest\";\n  if (severity === \"major\") return \"High\";\n  return \"Medium\";\n}\n\nfunction defaultSummary(description: string): string {\n  const first = description.split(/(?<=[.!?])\\s/)[0]?.trim() ?? description;\n  if (first.length <= 80) return first;\n  return first.slice(0, 79).trimEnd() + \"…\";\n}\n\nfunction buildDescription(issue: ValidatedIssue): string {\n  const lines: string[] = [];\n  lines.push(\"h2. Observed issue\");\n  lines.push(issue.description);\n  lines.push(\"\");\n  lines.push(\"h2. Category\");\n  lines.push(issue.category.replace(/_/g, \" \"));\n  lines.push(\"\");\n  lines.push(\"h2. AI Critic Verdict\");\n  lines.push(\n    `*${issue.verdict.replace(/_/g, \" \")}* — ${issue.criticReasoning}`\n  );\n  if (issue.timestamp) {\n    lines.push(\"\");\n    lines.push(\"h2. Reproduce at\");\n    lines.push(issue.timestamp);\n  }\n  lines.push(\"\");\n  lines.push(\"----\");\n  lines.push(\"_Generated by Video UX Analyzer_\");\n  return lines.join(\"\\n\");\n}\n\nfunction JiraIcon() {\n  return (\n    <svg viewBox=\"0 0 32 32\" className=\"w-8 h-8 shrink-0\">\n      <defs>\n        <linearGradient id=\"jiraGrad1\" x1=\"0%\" y1=\"0%\" x2=\"100%\" y2=\"100%\">\n          <stop offset=\"0%\" stopColor=\"#2684FF\" />\n          <stop offset=\"100%\" stopColor=\"#0052CC\" />\n        </linearGradient>\n        <linearGradient id=\"jiraGrad2\" x1=\"100%\" y1=\"0%\" x2=\"0%\" y2=\"100%\">\n          <stop offset=\"0%\" stopColor=\"#2684FF\" />\n          <stop offset=\"100%\" stopColor=\"#0052CC\" />\n        </linearGradient>\n      </defs>\n      <path d=\"M16 3 L28 15 L16 27 L13 24 L22 15 L13 6 Z\" fill=\"url(#jiraGrad1)\" />\n      <path d=\"M13 6 L22 15 L13 24 L4 15 Z\" fill=\"url(#jiraGrad2)\" opacity=\"0.9\" />\n    </svg>\n  );\n}\n\nexport default function JiraTicketModal({ issue, onClose }: Props) {\n  const [summary, setSummary] = useState(defaultSummary(issue.description));\n  const [issueType, setIssueType] = useState<IssueType>(\n    verdictToIssueType(issue.verdict)\n  );\n  const [priority, setPriority] = useState<Priority>(\n    severityToPriority(issue.severity)\n  );\n  const [labels, setLabels] = useState<string[]>([issue.category]);\n  const [description, setDescription] = useState(buildDescription(issue));\n  const [newLabel, setNewLabel] = useState(\"\");\n\n  useEffect(() => {\n    const handleKey = (e: KeyboardEvent) => {\n      if (e.key === \"Escape\") onClose();\n    };\n    document.addEventListener(\"keydown\", handleKey);\n    const prevOverflow = document.body.style.overflow;\n    document.body.style.overflow = \"hidden\";\n    return () => {\n      document.removeEventListener(\"keydown\", handleKey);\n      document.body.style.overflow = prevOverflow;\n    };\n  }, [onClose]);\n\n  const handleAddLabel = () => {\n    const trimmed = newLabel.trim().toLowerCase().replace(/\\s+/g, \"_\");\n    if (trimmed && !labels.includes(trimmed)) {\n      setLabels([...labels, trimmed]);\n    }\n    setNewLabel(\"\");\n  };\n\n  const handleRemoveLabel = (label: string) => {\n    setLabels(labels.filter((l) => l !== label));\n  };\n\n  const handleSubmit = () => {\n    const url = new URL(\n      `${JIRA_BASE_URL}/secure/CreateIssueDetails!init.jspa`\n    );\n    url.searchParams.set(\"pid\", JIRA_PROJECT_ID);\n    url.searchParams.set(\"issuetype\", issueType);\n    url.searchParams.set(\"summary\", summary);\n    url.searchParams.set(\"description\", description);\n    url.searchParams.set(\"priority\", priority);\n    if (labels.length) url.searchParams.set(\"labels\", labels.join(\",\"));\n    window.open(url.toString(), \"_blank\", \"noopener,noreferrer\");\n    onClose();\n  };\n\n  const pCfg = PRIORITY_CONFIG[priority];\n  const tCfg = ISSUE_TYPE_CONFIG[issueType];\n\n  return (\n    <div\n      className=\"fixed inset-0 z-50 flex items-center justify-center bg-black/70 backdrop-blur-sm p-4\"\n      onClick={onClose}\n    >\n      <div\n        className=\"bg-slate-900 border border-slate-700 rounded-2xl w-full max-w-2xl max-h-[90vh] flex flex-col overflow-hidden shadow-2xl\"\n        onClick={(e) => e.stopPropagation()}\n      >\n        {/* Header with Jira breadcrumb */}\n        <div className=\"flex items-center gap-3 px-6 py-4 border-b border-slate-800 bg-slate-900/60\">\n          <JiraIcon />\n          <div className=\"flex-1 min-w-0\">\n            <div className=\"flex items-center gap-1.5 text-xs text-slate-500\">\n              <span className=\"text-[#4c9aff] font-medium\">UX Project</span>\n              <span className=\"text-slate-600\">/</span>\n              <span>Analysis</span>\n            </div>\n            <p className=\"text-sm font-semibold text-slate-100 mt-0.5\">\n              Create Issue\n            </p>\n          </div>\n          <button\n            onClick={onClose}\n            className=\"text-slate-500 hover:text-slate-200 p-1 rounded hover:bg-slate-800 transition-colors\"\n            aria-label=\"Close\"\n          >\n            <svg className=\"w-5 h-5\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n              <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={2} d=\"M6 18L18 6M6 6l12 12\" />\n            </svg>\n          </button>\n        </div>\n\n        {/* Form body */}\n        <div className=\"flex-1 overflow-y-auto p-6 space-y-5\">\n          {/* Summary */}\n          <div>\n            <label className=\"block text-xs font-semibold text-slate-400 mb-1.5\">\n              Summary <span className=\"text-red-400\">*</span>\n            </label>\n            <input\n              type=\"text\"\n              value={summary}\n              onChange={(e) => setSummary(e.target.value)}\n              className=\"w-full px-3 py-2 bg-slate-950 border border-slate-700 rounded-lg text-sm text-slate-100 focus:border-[#4c9aff] focus:ring-1 focus:ring-[#4c9aff] focus:outline-none transition-colors\"\n            />\n          </div>\n\n          {/* Type & Priority row */}\n          <div className=\"grid grid-cols-2 gap-4\">\n            <div>\n              <label className=\"block text-xs font-semibold text-slate-400 mb-1.5\">\n                Issue Type\n              </label>\n              <div className=\"flex items-center gap-2 px-3 py-2 bg-slate-950 border border-slate-700 rounded-lg focus-within:border-[#4c9aff] transition-colors\">\n                <span\n                  className={`w-5 h-5 rounded flex items-center justify-center text-[10px] text-white ${tCfg.bg}`}\n                >\n                  {tCfg.icon}\n                </span>\n                <select\n                  value={issueType}\n                  onChange={(e) => setIssueType(e.target.value as IssueType)}\n                  className=\"flex-1 bg-transparent text-sm text-slate-100 focus:outline-none appearance-none cursor-pointer\"\n                >\n                  <option value=\"Bug\" className=\"bg-slate-900\">Bug</option>\n                  <option value=\"Task\" className=\"bg-slate-900\">Task</option>\n                  <option value=\"Spike\" className=\"bg-slate-900\">Spike</option>\n                  <option value=\"Story\" className=\"bg-slate-900\">Story</option>\n                </select>\n                <svg className=\"w-4 h-4 text-slate-500\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n                  <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={2} d=\"M19 9l-7 7-7-7\" />\n                </svg>\n              </div>\n            </div>\n            <div>\n              <label className=\"block text-xs font-semibold text-slate-400 mb-1.5\">\n                Priority\n              </label>\n              <div\n                className={`flex items-center gap-2 px-3 py-2 border rounded-lg transition-colors ${pCfg.wrap}`}\n              >\n                <span className={`font-bold text-base leading-none ${pCfg.iconColor}`}>\n                  {pCfg.icon}\n                </span>\n                <select\n                  value={priority}\n                  onChange={(e) => setPriority(e.target.value as Priority)}\n                  className=\"flex-1 bg-transparent text-sm focus:outline-none appearance-none cursor-pointer font-medium\"\n                >\n                  <option value=\"Highest\" className=\"bg-slate-900 text-slate-100\">Highest</option>\n                  <option value=\"High\" className=\"bg-slate-900 text-slate-100\">High</option>\n                  <option value=\"Medium\" className=\"bg-slate-900 text-slate-100\">Medium</option>\n                  <option value=\"Low\" className=\"bg-slate-900 text-slate-100\">Low</option>\n                  <option value=\"Lowest\" className=\"bg-slate-900 text-slate-100\">Lowest</option>\n                </select>\n                <svg className={`w-4 h-4 ${pCfg.iconColor}`} fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n                  <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={2} d=\"M19 9l-7 7-7-7\" />\n                </svg>\n              </div>\n            </div>\n          </div>\n\n          {/* Labels */}\n          <div>\n            <label className=\"block text-xs font-semibold text-slate-400 mb-1.5\">\n              Labels\n            </label>\n            <div className=\"flex flex-wrap items-center gap-2 px-3 py-2 bg-slate-950 border border-slate-700 rounded-lg min-h-[2.5rem] focus-within:border-[#4c9aff] transition-colors\">\n              {labels.map((l) => (\n                <span\n                  key={l}\n                  className={`inline-flex items-center gap-1.5 px-2 py-0.5 rounded-md text-xs font-medium border ${labelColor(l)}`}\n                >\n                  {l.replace(/_/g, \" \")}\n                  <button\n                    type=\"button\"\n                    onClick={() => handleRemoveLabel(l)}\n                    className=\"hover:text-white leading-none\"\n                    aria-label={`Remove ${l}`}\n                  >\n                    ×\n                  </button>\n                </span>\n              ))}\n              <input\n                type=\"text\"\n                value={newLabel}\n                onChange={(e) => setNewLabel(e.target.value)}\n                onKeyDown={(e) => {\n                  if (e.key === \"Enter\") {\n                    e.preventDefault();\n                    handleAddLabel();\n                  } else if (e.key === \"Backspace\" && !newLabel && labels.length) {\n                    handleRemoveLabel(labels[labels.length - 1]);\n                  }\n                }}\n                onBlur={handleAddLabel}\n                placeholder={labels.length ? \"\" : \"Add label...\"}\n                className=\"flex-1 min-w-[80px] bg-transparent text-xs text-slate-100 focus:outline-none\"\n              />\n            </div>\n          </div>\n\n          {/* Description */}\n          <div>\n            <label className=\"block text-xs font-semibold text-slate-400 mb-1.5\">\n              Description\n            </label>\n            <textarea\n              value={description}\n              onChange={(e) => setDescription(e.target.value)}\n              rows={9}\n              className=\"w-full px-3 py-2 bg-slate-950 border border-slate-700 rounded-lg text-xs text-slate-200 font-mono leading-relaxed focus:border-[#4c9aff] focus:ring-1 focus:ring-[#4c9aff] focus:outline-none resize-y\"\n            />\n          </div>\n\n          {/* Reporter / Assignee */}\n          <div className=\"grid grid-cols-2 gap-4\">\n            <div>\n              <label className=\"block text-xs font-semibold text-slate-400 mb-1.5\">\n                Reporter\n              </label>\n              <div className=\"flex items-center gap-2 px-3 py-2 bg-slate-950 border border-slate-700 rounded-lg\">\n                <div className=\"w-6 h-6 rounded-full bg-gradient-to-br from-violet-500 to-violet-700 flex items-center justify-center text-xs font-bold text-white\">\n                  U\n                </div>\n                <span className=\"text-sm text-slate-300\">UX Analyzer Bot</span>\n              </div>\n            </div>\n            <div>\n              <label className=\"block text-xs font-semibold text-slate-400 mb-1.5\">\n                Assignee\n              </label>\n              <div className=\"flex items-center gap-2 px-3 py-2 bg-slate-950 border border-slate-700 rounded-lg\">\n                <div className=\"w-6 h-6 rounded-full bg-slate-700 border border-dashed border-slate-500 flex items-center justify-center text-xs text-slate-400\">\n                  ?\n                </div>\n                <span className=\"text-sm text-slate-500\">Unassigned</span>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        {/* Footer actions */}\n        <div className=\"px-6 py-4 border-t border-slate-800 bg-slate-900/60 flex items-center justify-between gap-3\">\n          <p className=\"text-xs text-slate-600 hidden sm:block\">\n            Opens Jira in a new tab with fields pre-filled\n          </p>\n          <div className=\"flex gap-2 ml-auto\">\n            <button\n              onClick={onClose}\n              className=\"px-4 py-2 text-sm text-slate-300 hover:bg-slate-800 rounded-lg transition-colors\"\n            >\n              Cancel\n            </button>\n            <button\n              onClick={handleSubmit}\n              disabled={!summary.trim()}\n              className=\"px-4 py-2 text-sm font-medium bg-[#0052CC] hover:bg-[#0747A6] text-white rounded-lg disabled:opacity-50 disabled:cursor-not-allowed transition-colors shadow-sm\"\n            >\n              Create Issue\n            </button>\n          </div>\n        </div>\n      </div>\n    </div>\n  );\n}\n","structuredPatch":[],"originalFile":null,"userModified":false},"sourceToolAssistantUUID":"33a35ecb-be5f-4234-a108-1e851a36cadf","userType":"external","entrypoint":"claude-vscode","cwd":"/home/akshay/projects/video_ux_analyzer","sessionId":"43aa6f4e-238a-49ff-bcee-676bf9b5ead2","version":"2.1.118","gitBranch":"HEAD"}
