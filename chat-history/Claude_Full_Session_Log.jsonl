{"parentUuid":"ed21ba6a-cc53-440c-ba8b-18d9b9802730","isSidechain":false,"message":{"model":"claude-sonnet-4-6","id":"msg_01BcWSAgDQBUh77mVVdMqspG","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_013QUFU9ngX19e4xmPYWRNY6","name":"Write","input":{"file_path":"/home/akshay/projects/video_ux_analyzer/src/app/page.tsx","content":"\"use client\";\n\nimport { useState } from \"react\";\nimport VideoUploader from \"@/components/VideoUploader\";\nimport AnalysisResults from \"@/components/AnalysisResults\";\nimport type { AnalysisResult, AnalysisStage } from \"@/types/analysis\";\n\nexport default function Home() {\n  const [videoFile, setVideoFile] = useState<File | null>(null);\n  const [videoUrl, setVideoUrl] = useState(\"\");\n  const [stage, setStage] = useState<AnalysisStage>(\"idle\");\n  const [message, setMessage] = useState(\"\");\n  const [analysisData, setAnalysisData] = useState<AnalysisResult | null>(null);\n  const [researcherCount, setResearcherCount] = useState(0);\n\n  const handleFileSelect = (file: File) => {\n    if (videoUrl) URL.revokeObjectURL(videoUrl);\n    setVideoFile(file);\n    setVideoUrl(URL.createObjectURL(file));\n    setStage(\"idle\");\n    setAnalysisData(null);\n    setResearcherCount(0);\n  };\n\n  const handleReset = () => {\n    if (videoUrl) URL.revokeObjectURL(videoUrl);\n    setVideoFile(null);\n    setVideoUrl(\"\");\n    setStage(\"idle\");\n    setAnalysisData(null);\n    setResearcherCount(0);\n    setMessage(\"\");\n  };\n\n  const handleAnalyze = async () => {\n    if (!videoFile) return;\n\n    setStage(\"uploading\");\n    setMessage(\"Receiving video file...\");\n    setAnalysisData(null);\n\n    const formData = new FormData();\n    formData.append(\"video\", videoFile);\n\n    try {\n      const response = await fetch(\"/api/analyze\", {\n        method: \"POST\",\n        body: formData,\n      });\n\n      if (!response.body) throw new Error(\"No response body.\");\n\n      const reader = response.body.getReader();\n      const decoder = new TextDecoder();\n\n      while (true) {\n        const { done, value } = await reader.read();\n        if (done) break;\n\n        const text = decoder.decode(value, { stream: true });\n        const lines = text.split(\"\\n\").filter((l) => l.startsWith(\"data: \"));\n\n        for (const line of lines) {\n          try {\n            const event = JSON.parse(line.slice(6));\n            setStage(event.stage as AnalysisStage);\n            if (event.message) setMessage(event.message);\n            if (event.researcherCount !== undefined)\n              setResearcherCount(event.researcherCount);\n            if (event.stage === \"complete\" && event.data) {\n              setAnalysisData(event.data as AnalysisResult);\n            }\n          } catch {\n            // skip malformed lines\n          }\n        }\n      }\n    } catch (err) {\n      setStage(\"error\");\n      setMessage(err instanceof Error ? err.message : \"Analysis failed.\");\n    }\n  };\n\n  const isAnalyzing = [\"uploading\", \"processing\", \"researching\", \"critiquing\"].includes(stage);\n\n  return (\n    <div className=\"min-h-screen bg-slate-950 text-white\">\n      <header className=\"border-b border-slate-800/60 bg-slate-950/80 backdrop-blur-sm sticky top-0 z-10\">\n        <div className=\"max-w-7xl mx-auto px-6 py-4 flex items-center gap-3\">\n          <div className=\"w-7 h-7 bg-violet-600 rounded-lg flex items-center justify-center text-xs font-bold\">\n            UX\n          </div>\n          <span className=\"text-sm font-semibold text-slate-200\">\n            Video UX Analyzer\n          </span>\n          <span className=\"text-xs text-slate-600 ml-auto\">\n            Gemini · LangGraph\n          </span>\n        </div>\n      </header>\n\n      <main className=\"max-w-7xl mx-auto px-6 py-10\">\n        <div className=\"grid grid-cols-1 lg:grid-cols-2 gap-10 items-start\">\n          <VideoUploader\n            onFileSelect={handleFileSelect}\n            videoUrl={videoUrl}\n            onAnalyze={handleAnalyze}\n            onReset={handleReset}\n            isAnalyzing={isAnalyzing}\n          />\n          <AnalysisResults\n            stage={stage}\n            message={message}\n            data={analysisData}\n            researcherCount={researcherCount}\n          />\n        </div>\n      </main>\n    </div>\n  );\n}\n"},"caller":{"type":"direct"}}],"stop_reason":"tool_use","stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":5140,"cache_read_input_tokens":55454,"output_tokens":1359,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":5140,"ephemeral_5m_input_tokens":0},"inference_geo":"","iterations":[{"input_tokens":1,"output_tokens":1359,"cache_read_input_tokens":55454,"cache_creation_input_tokens":5140,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":5140},"type":"message"}],"speed":"standard"}},"requestId":"req_011CaJiuhCGV8K3i8NbZQcrg","type":"assistant","uuid":"9d616e09-31b6-4ace-aa55-7193914bd7d9","timestamp":"2026-04-22T11:23:01.202Z","userType":"external","entrypoint":"claude-vscode","cwd":"/home/akshay/projects/video_ux_analyzer","sessionId":"43aa6f4e-238a-49ff-bcee-676bf9b5ead2","version":"2.1.111","gitBranch":"HEAD"}
