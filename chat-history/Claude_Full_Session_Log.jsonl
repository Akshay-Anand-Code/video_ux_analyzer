{"parentUuid":"5a4c7bc2-1004-4486-807e-a7fcdf24b2b4","isSidechain":false,"promptId":"d3617822-df31-4211-9ed4-8dcd9155784c","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HdCoVpNTVoZzmWPvm2HbAv","type":"tool_result","content":"File created successfully at: /home/akshay/projects/video_ux_analyzer/src/components/AnalysisResults.tsx (file state is current in your context — no need to Read it back)"}]},"uuid":"d18bb409-64e6-4633-9a8e-74ce06eee6dc","timestamp":"2026-04-22T11:22:46.367Z","toolUseResult":{"type":"create","filePath":"/home/akshay/projects/video_ux_analyzer/src/components/AnalysisResults.tsx","content":"\"use client\";\n\nimport type { AnalysisResult, AnalysisStage, ValidatedIssue } from \"@/types/analysis\";\n\ninterface Props {\n  stage: AnalysisStage;\n  message: string;\n  data: AnalysisResult | null;\n  researcherCount: number;\n}\n\nconst STEPS = [\n  {\n    key: \"upload\",\n    label: \"Upload & Process\",\n    activeStages: [\"uploading\", \"processing\"] as AnalysisStage[],\n  },\n  {\n    key: \"research\",\n    label: \"UX Research\",\n    activeStages: [\"researching\"] as AnalysisStage[],\n  },\n  {\n    key: \"critic\",\n    label: \"Critic Review\",\n    activeStages: [\"critiquing\"] as AnalysisStage[],\n  },\n];\n\nconst STAGE_ORDER: AnalysisStage[] = [\n  \"idle\",\n  \"uploading\",\n  \"processing\",\n  \"researching\",\n  \"critiquing\",\n  \"complete\",\n];\n\nfunction getStepStatus(\n  step: (typeof STEPS)[0],\n  currentStage: AnalysisStage\n): \"pending\" | \"active\" | \"done\" {\n  const currentIndex = STAGE_ORDER.indexOf(currentStage);\n  const stepFirstIndex = Math.min(\n    ...step.activeStages.map((s) => STAGE_ORDER.indexOf(s))\n  );\n  const stepLastIndex = Math.max(\n    ...step.activeStages.map((s) => STAGE_ORDER.indexOf(s))\n  );\n  if (currentIndex > stepLastIndex) return \"done\";\n  if (currentIndex >= stepFirstIndex) return \"active\";\n  return \"pending\";\n}\n\nconst VERDICT_CONFIG = {\n  genuine_bug: {\n    label: \"Genuine Bug\",\n    dot: \"bg-red-500\",\n    badge: \"bg-red-500/15 text-red-400 border border-red-500/25\",\n  },\n  stylistic_choice: {\n    label: \"Stylistic Choice\",\n    dot: \"bg-sky-500\",\n    badge: \"bg-sky-500/15 text-sky-400 border border-sky-500/25\",\n  },\n  needs_investigation: {\n    label: \"Needs Investigation\",\n    dot: \"bg-amber-500\",\n    badge: \"bg-amber-500/15 text-amber-400 border border-amber-500/25\",\n  },\n};\n\nconst SEVERITY_CONFIG = {\n  critical: { label: \"Critical\", cls: \"bg-red-600/20 text-red-400 border border-red-600/30\" },\n  major: { label: \"Major\", cls: \"bg-orange-600/20 text-orange-400 border border-orange-600/30\" },\n  minor: { label: \"Minor\", cls: \"bg-yellow-600/20 text-yellow-400 border border-yellow-600/30\" },\n};\n\nconst CATEGORY_LABELS: Record<string, string> = {\n  navigation: \"Navigation\",\n  ui_element: \"UI Element\",\n  user_flow: \"User Flow\",\n  accessibility: \"Accessibility\",\n  interaction_delay: \"Interaction Delay\",\n  unclear_messaging: \"Unclear Messaging\",\n};\n\nfunction IssueCard({ issue }: { issue: ValidatedIssue }) {\n  const verdict = VERDICT_CONFIG[issue.verdict];\n  const severity = SEVERITY_CONFIG[issue.severity];\n\n  return (\n    <div className=\"bg-slate-900 border border-slate-800 rounded-xl p-4 space-y-3\">\n      <div className=\"flex items-start justify-between gap-3\">\n        <div className=\"flex flex-wrap gap-2\">\n          <span className=\"text-xs px-2 py-0.5 rounded-md bg-slate-800 text-slate-400 border border-slate-700\">\n            {CATEGORY_LABELS[issue.category] ?? issue.category}\n          </span>\n          <span className={`text-xs px-2 py-0.5 rounded-md font-medium ${severity.cls}`}>\n            {severity.label}\n          </span>\n        </div>\n        <span className={`shrink-0 text-xs px-2.5 py-1 rounded-full font-medium flex items-center gap-1.5 ${verdict.badge}`}>\n          <span className={`w-1.5 h-1.5 rounded-full ${verdict.dot}`} />\n          {verdict.label}\n        </span>\n      </div>\n\n      <p className=\"text-sm text-slate-200 leading-relaxed\">{issue.description}</p>\n\n      <div className=\"space-y-1.5\">\n        {issue.timestamp && (\n          <p className=\"text-xs text-slate-500 flex items-center gap-1.5\">\n            <svg className=\"w-3 h-3\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n              <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={2} d=\"M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z\" />\n            </svg>\n            {issue.timestamp}\n          </p>\n        )}\n        <p className=\"text-xs text-slate-500 italic leading-relaxed\">\n          <span className=\"text-slate-600 not-italic\">Critic: </span>\n          {issue.criticReasoning}\n        </p>\n      </div>\n    </div>\n  );\n}\n\nfunction sortIssues(issues: ValidatedIssue[]): ValidatedIssue[] {\n  const severityOrder = { critical: 0, major: 1, minor: 2 };\n  const verdictOrder = { genuine_bug: 0, needs_investigation: 1, stylistic_choice: 2 };\n  return [...issues].sort(\n    (a, b) =>\n      severityOrder[a.severity] - severityOrder[b.severity] ||\n      verdictOrder[a.verdict] - verdictOrder[b.verdict]\n  );\n}\n\nexport default function AnalysisResults({ stage, message, data, researcherCount }: Props) {\n  const isActive = stage !== \"idle\" && stage !== \"complete\" && stage !== \"error\";\n\n  if (stage === \"idle\") {\n    return (\n      <div className=\"h-full flex flex-col items-center justify-center py-24 text-center gap-4\">\n        <div className=\"w-16 h-16 rounded-2xl bg-slate-900 border border-slate-800 flex items-center justify-center\">\n          <svg className=\"w-8 h-8 text-slate-600\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n            <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={1.5}\n              d=\"M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2\"\n            />\n          </svg>\n        </div>\n        <div>\n          <p className=\"text-sm font-medium text-slate-400\">No analysis yet</p>\n          <p className=\"text-xs text-slate-600 mt-1\">Upload a video and click Analyze UX</p>\n        </div>\n      </div>\n    );\n  }\n\n  if (stage === \"error\") {\n    return (\n      <div className=\"bg-red-900/20 border border-red-800/50 rounded-2xl p-6 space-y-2\">\n        <p className=\"text-sm font-semibold text-red-400\">Analysis failed</p>\n        <p className=\"text-xs text-red-400/70\">{message}</p>\n      </div>\n    );\n  }\n\n  return (\n    <div className=\"space-y-6\">\n      <h2 className=\"text-xs font-semibold text-slate-500 uppercase tracking-widest\">\n        Analysis Results\n      </h2>\n\n      {/* Progress stepper */}\n      {isActive && (\n        <div className=\"bg-slate-900 border border-slate-800 rounded-2xl p-5 space-y-4\">\n          <div className=\"space-y-3\">\n            {STEPS.map((step) => {\n              const status = getStepStatus(step, stage);\n              return (\n                <div key={step.key} className=\"flex items-center gap-3\">\n                  <div className={`w-5 h-5 rounded-full flex items-center justify-center shrink-0 transition-all\n                    ${status === \"done\" ? \"bg-violet-600\" : status === \"active\" ? \"bg-violet-600/30 ring-2 ring-violet-500\" : \"bg-slate-800\"}\n                  `}>\n                    {status === \"done\" ? (\n                      <svg className=\"w-3 h-3 text-white\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n                        <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={2.5} d=\"M5 13l4 4L19 7\" />\n                      </svg>\n                    ) : status === \"active\" ? (\n                      <div className=\"w-2 h-2 rounded-full bg-violet-400 animate-pulse\" />\n                    ) : (\n                      <div className=\"w-2 h-2 rounded-full bg-slate-600\" />\n                    )}\n                  </div>\n                  <span className={`text-sm transition-colors\n                    ${status === \"active\" ? \"text-slate-200 font-medium\" : status === \"done\" ? \"text-slate-400\" : \"text-slate-600\"}\n                  `}>\n                    {step.label}\n                    {status === \"active\" && step.key === \"critic\" && researcherCount > 0 && (\n                      <span className=\"text-slate-500 font-normal\"> · reviewing {researcherCount} findings</span>\n                    )}\n                  </span>\n                </div>\n              );\n            })}\n          </div>\n          <p className=\"text-xs text-slate-500 pt-1 border-t border-slate-800\">{message}</p>\n        </div>\n      )}\n\n      {/* Results */}\n      {stage === \"complete\" && data && (\n        <div className=\"space-y-5\">\n          {/* Stats */}\n          <div className=\"grid grid-cols-3 gap-3\">\n            {[\n              { label: \"Total Issues\", value: data.validatedIssues.length, color: \"text-slate-200\" },\n              {\n                label: \"Genuine Bugs\",\n                value: data.validatedIssues.filter((i) => i.verdict === \"genuine_bug\").length,\n                color: \"text-red-400\",\n              },\n              {\n                label: \"Stylistic\",\n                value: data.validatedIssues.filter((i) => i.verdict === \"stylistic_choice\").length,\n                color: \"text-sky-400\",\n              },\n            ].map((stat) => (\n              <div key={stat.label} className=\"bg-slate-900 border border-slate-800 rounded-xl p-3 text-center\">\n                <p className={`text-2xl font-bold ${stat.color}`}>{stat.value}</p>\n                <p className=\"text-xs text-slate-500 mt-0.5\">{stat.label}</p>\n              </div>\n            ))}\n          </div>\n\n          {/* Overall assessment */}\n          <div className=\"bg-violet-900/20 border border-violet-800/40 rounded-xl p-4\">\n            <p className=\"text-xs font-semibold text-violet-400 mb-2 uppercase tracking-wider\">Overall Assessment</p>\n            <p className=\"text-sm text-slate-300 leading-relaxed\">{data.overallAssessment}</p>\n          </div>\n\n          {/* Issue cards */}\n          <div className=\"space-y-3\">\n            {sortIssues(data.validatedIssues).map((issue) => (\n              <IssueCard key={issue.id} issue={issue} />\n            ))}\n          </div>\n        </div>\n      )}\n    </div>\n  );\n}\n","structuredPatch":[],"originalFile":null,"userModified":false},"sourceToolAssistantUUID":"5a4c7bc2-1004-4486-807e-a7fcdf24b2b4","userType":"external","entrypoint":"claude-vscode","cwd":"/home/akshay/projects/video_ux_analyzer","sessionId":"43aa6f4e-238a-49ff-bcee-676bf9b5ead2","version":"2.1.111","gitBranch":"HEAD"}
