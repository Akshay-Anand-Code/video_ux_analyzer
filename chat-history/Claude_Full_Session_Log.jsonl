{"parentUuid":"d061cdc4-007c-46af-acd8-57fa280b7fb8","isSidechain":false,"attachment":{"type":"edited_text_file","filename":"/home/akshay/projects/video_ux_analyzer/src/lib/langgraph/nodes/synthesizer.ts","snippet":"1\timport { GoogleGenerativeAI } from \"@google/generative-ai\";\n2\timport type { AppState } from \"../state\";\n3\timport { callGeminiWithRetry } from \"./gemini-utils\";\n4\t\n5\tconst genAI = new GoogleGenerativeAI(process.env.GEMINI_API_KEY!);\n6\t\n7\tconst SYSTEM_INSTRUCTION = `You are a VP of Design synthesizing findings from a UX audit. You produce concise, \\\n8\texecutive-level summaries that help product leaders prioritize. You never list individual issues — you surface \\\n9\tthe overall quality signal and the top 1-2 priority areas.`;\n10\t\n11\tfunction buildPrompt(validatedJson: string): string {\n...\n27\t      };\n28\t    }\n29\t\n30\t    const model = genAI.getGenerativeModel({\n31\t      model: \"gemini-2.5-flash\",\n32\t      systemInstruction: SYSTEM_INSTRUCTION,\n33\t    });\n34\t\n35\t    const result = await callGeminiWithRetry(() =>\n36\t      model.generateContent(\n37\t        buildPrompt(JSON.stringify(state.validatedIssues, null, 2))\n38\t      )\n39\t    );\n40\t\n41\t    return { overallAssessment: result.response.text().trim() };\n42\t  } catch (err) {\n43\t    return {\n44\t      error: `Synthesizer failed: ${err instanceof Error ? err.message : String(err)}`,\n45\t    };\n46\t  }"},"type":"attachment","uuid":"0dfd309c-7453-452b-a155-a785fc628308","timestamp":"2026-04-26T19:12:09.593Z","userType":"external","entrypoint":"claude-vscode","cwd":"/home/akshay/projects/video_ux_analyzer","sessionId":"43aa6f4e-238a-49ff-bcee-676bf9b5ead2","version":"2.1.120","gitBranch":"main"}
{"parentUuid":"0dfd309c-7453-452b-a155-a785fc628308","isSidechain":false,"attachment":{"type":"edited_text_file","filename":"/home/akshay/projects/video_ux_analyzer/src/lib/langgraph/nodes/critic.ts","snippet":"1\timport { GoogleGenerativeAI } from \"@google/generative-ai\";\n2\timport type { AppState } from \"../state\";\n3\timport type { UXIssue, ValidatedIssue } from \"@/types/analysis\";\n4\timport { callGeminiWithRetry, createLimiter } from \"./gemini-utils\";\n5\t\n6\tconst criticLimit = createLimiter(3);\n7\t\n8\tconst genAI = new GoogleGenerativeAI(process.env.GEMINI_API_KEY!);\n9\t\n10\tconst SYSTEM_INSTRUCTION = `You are a VP of Design at a Series B SaaS company with deep expertise in both UX \\\n11\tresearch and product strategy. You've reviewed hundreds of UX research reports and you know that not every rough \\\n12\tedge is a bug — some are intentional design decisions, brand choices, or platform conventions.\n13\t\n14\tYour role is to critically validate a single UX finding at a time, distinguishing genuine usability bugs from \\\n15\tstylistic choices or ambiguous cases. You are balanced, thoughtful, and consider business context alongside user needs.`;\n...\n42\t\n43\texport async function criticNode(input: CriticInput): Promise<Partial<AppState>> {\n44\t  try {\n45\t    const model = genAI.getGenerativeModel({\n46\t      model: \"gemini-2.5-flash\",\n47\t      systemInstruction: SYSTEM_INSTRUCTION,\n48\t    });\n49\t\n50\t    const result = await criticLimit(() =>\n51\t      callGeminiWithRetry(() =>\n52\t        model.generateContent(buildPrompt(JSON.stringify(input.issue, null, 2)))\n53\t      )\n54\t    );\n55\t\n56\t    const { verdict, criticReasoning } = extractJSON<{\n57\t      verdict: ValidatedIssue[\"verdict\"];\n58\t      criticReasoning: string;\n59\t    }>(result.response.text());\n60\t\n61\t    const validatedIssue: ValidatedIssue = {"},"type":"attachment","uuid":"4b82de24-6fdf-44b0-bc5c-ae00c5e6d103","timestamp":"2026-04-26T19:12:09.593Z","userType":"external","entrypoint":"claude-vscode","cwd":"/home/akshay/projects/video_ux_analyzer","sessionId":"43aa6f4e-238a-49ff-bcee-676bf9b5ead2","version":"2.1.120","gitBranch":"main"}
{"parentUuid":"4b82de24-6fdf-44b0-bc5c-ae00c5e6d103","isSidechain":false,"attachment":{"type":"edited_text_file","filename":"/home/akshay/projects/video_ux_analyzer/NOTES.md","snippet":"1\t# Video UX Analyzer — Notes\n2\t\n3\tA Next.js + LangGraph + Gemini app that analyzes product demo videos for UX issues. A two-stage AI pipeline (UX Researcher → parallel Critic validators → Synthesizer) streams findings progressively to a polished light-theme UI inspired by the Twisty dashboard reference.\n4\t\n5\t---\n6\t\n7\t## High-Level Design\n8\t\n9\t```\n10\tBrowser\n11\t  │  FormData (video file)\n12\t  ▼\n13\tNext.js API Route (/api/analyze)\n14\t  │  SSE stream (stage updates + per-issue events)\n15\t  │\n16\t  ├── 1. uploadVideoToGemini()\n17\t  │       └── Buffer → temp file → GoogleAIFileManager.uploadFile()\n18\t  │           Poll until FileState.ACTIVE\n19\t  │\n20\t  └── 2. LangGraph (graph.stream, streamMode: \"updates\")\n21\t          │\n22\t          ├── Node: researcher\n23\t          │     └── gemini-2.5-flash + video URI\n24\t          │         System prompt: \"Senior UX Researcher at NN/g\"\n25\t          │         Output: UXIssue[] (JSON, one batch)\n26\t          │\n27\t          ├── Send fan-out — one critic invocation per finding\n28\t          │\n29\t          ├── Node: critic × N (parallel)\n30\t          │     └── gemini-2.5-flash + single issue\n31\t          │         System prompt: \"VP of Design\"\n32\t          │         Output: ValidatedIssue (verdict + reasoning)\n33\t          │     Reducer: validatedIssues = [...left, ...right]  // append\n34\t          │\n35\t          └── Node: synthesizer (barrier, runs once after all critics)\n36\t                └── gemini-2.5-flash + all validated issues\n37\t                    Output: overallAssessment (plain text)\n38\t```\n39\t\n40\t### Why LangGraph (and why this shape)\n41\t\n42\tUX feedback is subjective. A single LLM pass over-reports rough edges as critical bugs. The graph separates concerns:\n43\t\n44\t- **Researcher** simulates a first-time user mentally walking through the demo, returns *all* findings in one batch.\n45\t- **Critic** (fan-out) evaluates *each* finding independently — `genuine_bug` / `stylistic_choice` / `needs_investigation`. Running them in parallel via `Send` is faster and keeps each critic call focused on one finding.\n46\t- **Synthesizer** is a barrier — LangGraph waits for all critic invocations to converge before producing the executive summary.\n47\t\n48\tState uses `Annotation.Root` with explicit reducers — `validatedIssues` uses an append reducer so parallel critic outputs merge correctly into the parent state.\n49\t\n50\t### Real-time UX (SSE)\n51\t\n52\tThe API route consumes `graph.stream(..., { streamMode: \"updates\" })` and emits Server-Sent Events as each node completes:\n53\t\n54\t| Stage | Trigger | Frontend behavior |\n55\t| --- | --- | --- |\n56\t| `uploading` | Form data received | Spinner |\n57\t| `processing` | Uploading + polling Gemini Files API | Spinner |\n58\t| `researching` | Researcher node started | Stepper highlights research |\n59\t| `validating` (researcher_complete) | Researcher returned N findings | Skeleton cards render with shimmer for each finding |\n60\t| `validating` (issue_validated × N) | Each critic completes | Skeleton swaps to validated card with verdict; stat counters tick up |\n61\t| `synthesizing` | All critics done, synthesizer running | Spinner |\n62\t| `complete` | Synthesizer returned overall assessment | Gradient assessment card fades in |\n63\t\n64\tThe user never stares at a blank loading screen — content materializes progressively.\n65\t\n66\t### Frontend stack\n67\t\n68\t- Next.js 15 (App Router) + TypeScript\n69\t- Tailwind CSS + shadcn/ui (Dialog, Tabs, Button) backed by Radix primitives\n70\t- Light theme tuned to match a Twisty-style dashboard: white cards on a soft off-white background, generous radii, soft pastel pill colors, large stat numbers, gradient Overall Assessment card\n71\t- Lucide icons throughout\n72\t- Per-category icon chips (Compass / MousePointer2 / Workflow / Accessibility / Clock / MessageSquare) for visual scanability\n73\t\n74\t### Key features\n75\t\n76\t- **Drag-drop video upload** with native HTML5 player\n77\t- **Live progress stepper** (4 phases) with stage-specific messaging\n78\t- **Skeleton-fill cards** — researcher findings render immediately, then each card swaps to the validated version as the critic resolves it\n79\t- **Timestamp video sync** — clicking a timestamp on any issue card seeks the video player to that moment and plays\n80\t- **Jira ticket modal** (shadcn Dialog) with two tabs:\n81\t  - *Details* — Summary, Issue Type, dynamic-color Priority badge, Labels (chip input), Description (Jira wiki markup pre-filled), Reporter/Assignee\n82\t  - *Attachments* — Mock video-snippet clipper centered on the issue's timestamp (UI scaffolds the eventual real feature)\n83\t- **URL-template Jira creation** — opens `/secure/CreateIssueDetails!init.jspa?pid=…&issuetype=…&summary=…&description=…&priority=…&labels=…` in a new tab; configurable via `NEXT_PUBLIC_JIRA_BASE_URL` and `NEXT_PUBLIC_JIRA_PROJECT_ID`\n84\t- **Severity / Verdict mapping** — defaults are editable in the modal (critical→Highest, genuine_bug→Bug, etc.)\n85\t\n86\t---\n87\t\n88\t## How to Run\n89\t\n90\t### Prerequisites\n91\t- Node.js 18+\n92\t- A Google Gemini API key — [Google AI Studio](https://aistudio.google.com)\n93\t\n94\t### Setup\n95\t\n96\t```bash\n97\tcd video_ux_analyzer\n98\t\n99\tnpm install\n100\t\n101\tcp .env.local.example .env.local\n102\t# edit .env.local — add GEMINI_API_KEY (required)\n103\t# optionally set NEXT_PUBLIC_JIRA_BASE_URL and NEXT_PUBLIC_JIRA_PROJECT_ID\n104\t#   for the Jira modal's \"Create Issue\" deep-link\n105\t\n106\tnpm run dev\n107\t```\n108\t\n109\tOpen [http://localhost:3000](http://localhost:3000), drop in a 1–5 min product demo, click **Analyze UX**. Findings stream in within ~30–90 seconds depending on video length.\n110\t\n111\t---\n112\t\n113\t## Production Concerns\n114\t\n115\t### 1. Video upload size & latency\n116\tVideo flows browser → Next.js → Gemini, doubling bandwidth. Vercel serverless has a ~4.5 MB body limit; we set `bodySizeLimit: 200mb` for local dev but that won't survive deployment.\n117\t\n118\t**Fix:** Generate a short-lived upload token server-side and have the browser upload directly to Gemini's Files API (or to S3 with a presigned URL, then trigger processing via a background queue).\n119\t\n120\t### 2. Serverless timeout\n121\tGemini video processing + a researcher pass + N parallel critic passes + synthesizer can exceed 60 s for longer videos. Vercel's default is 60 s (300 s on Pro).\n122\t\n123\t**Fix:** Move to a background queue (Inngest, BullMQ, Cloud Tasks). Return a job ID immediately; SSE re-attaches via job ID for resume. Or run on a long-running container.\n124\t\n125\t### 3. Gemini Files API retention\n126\tFiles auto-delete after 48 h. Any history / re-analysis feature requires storing the original video elsewhere (S3) and re-uploading.\n127\t\n128\t### 4. JSON parsing brittleness\n129\tBoth nodes ask Gemini for raw JSON and parse with regex + `JSON.parse`. Under unusual content the model may produce malformed output.\n130\t\n131\t**Fix:** Use Gemini's structured output (response schema / function calling) to enforce JSON at the API level — eliminates string parsing.\n132\t\n133\t### 5. No auth or rate limiting\n134\t`/api/analyze` is open. Each request burns Gemini quota and is expensive.\n135\t\n136\t**Fix:** Add NextAuth / Clerk + per-user rate limits via Upstash Redis.\n137\t\n138\t### 6. Error recovery in the graph\n139\tA failed critic currently fills in a `needs_investigation` fallback; a failed researcher kills the entire run. There's no resume capability.\n140\t\n141\t**Fix:** Persist node outputs to Redis keyed by job ID so a critic retry resumes from saved researcher findings without re-processing the video.\n142\t\n143\t### 7. Prompt versioning\n144\tPrompts and model IDs are hardcoded in node files. Tuning requires a deploy.\n145\t\n146\t**Fix:** Store prompts in a database / CMS with versioning + A/B testing.\n147\t\n148\t### 8. Real Jira integration\n149\tThe \"Create Issue\" button uses a URL template — the user lands on Jira's create form pre-filled but still has to click Create. A logged-in user with Jira API access expects one-click creation.\n150\t\n151\t**Fix:** Add OAuth → POST to `/rest/api/3/issue`. Map verdict/severity/category to real Jira issue type IDs and priority IDs (currently we send name strings).\n152\t\n153\t### 9. Mock video snippet attachment\n\n... [21 lines truncated] ..."},"type":"attachment","uuid":"d9a892f7-5696-44ca-aa32-c6910c3df600","timestamp":"2026-04-26T19:12:09.593Z","userType":"external","entrypoint":"claude-vscode","cwd":"/home/akshay/projects/video_ux_analyzer","sessionId":"43aa6f4e-238a-49ff-bcee-676bf9b5ead2","version":"2.1.120","gitBranch":"main"}
{"parentUuid":"d9a892f7-5696-44ca-aa32-c6910c3df600","isSidechain":false,"attachment":{"type":"edited_text_file","filename":"/home/akshay/projects/video_ux_analyzer/src/lib/langgraph/nodes/researcher.ts","snippet":"1\timport { GoogleGenerativeAI } from \"@google/generative-ai\";\n2\timport type { AppState } from \"../state\";\n3\timport type { UXIssue } from \"@/types/analysis\";\n4\timport { callGeminiWithRetry } from \"./gemini-utils\";\n5\t\n6\tconst genAI = new GoogleGenerativeAI(process.env.GEMINI_API_KEY!);\n7\t\n8\tconst SYSTEM_INSTRUCTION = `You are a Senior UX Researcher at Nielsen Norman Group with 15 years of experience \\\n9\tanalyzing enterprise and consumer SaaS products. You've evaluated hundreds of digital products and your analyses \\\n10\tare evidence-based, specific, and focused on measurable user impact.\n11\t\n12\tWhen watching a product demo, you mentally simulate being a first-time user — noting every moment of confusion, \\\n...\n39\t  return JSON.parse(cleaned) as T;\n40\t}\n41\t\n42\texport async function researcherNode(\n43\t  state: AppState\n44\t): Promise<Partial<AppState>> {\n45\t  try {\n46\t    const model = genAI.getGenerativeModel({\n47\t      model: \"gemini-2.5-flash\",\n48\t      systemInstruction: SYSTEM_INSTRUCTION,\n49\t    });\n50\t\n51\t    const result = await callGeminiWithRetry(() =>\n52\t      model.generateContent([\n53\t        { fileData: { mimeType: state.videoMimeType, fileUri: state.videoUri } },\n54\t        { text: PROMPT },\n55\t      ])\n56\t    );\n57\t\n58\t    const findings = extractJSON<UXIssue[]>(result.response.text());\n59\t    return { researcherFindings: findings };\n60\t  } catch (err) {\n61\t    return {\n62\t      error: `Researcher failed: ${err instanceof Error ? err.message : String(err)}`,\n63\t    };\n64\t  }"},"type":"attachment","uuid":"2b53c2ea-f141-4446-b398-d95ff97cb56c","timestamp":"2026-04-26T19:12:09.593Z","userType":"external","entrypoint":"claude-vscode","cwd":"/home/akshay/projects/video_ux_analyzer","sessionId":"43aa6f4e-238a-49ff-bcee-676bf9b5ead2","version":"2.1.120","gitBranch":"main"}
